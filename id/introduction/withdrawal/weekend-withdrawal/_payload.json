ntuk fitur ini.",[217,218],"hr",{},[220,221,223],"h2",{"id":222},"pengertian-weekend-withdrawal","Pengertian Weekend Withdrawal",[225,226,228],"h3",{"id":227},"apa-itu-weekend-withdrawal","Apa itu Weekend Withdrawal?",[209,230,231,232,235,236,239],{},"Secara default, settlement di TriPay hanya diproses pada ",[212,233,234],{},"Hari Kerja"," (Senin-Jumat). ",[212,237,238],{},"Weekend Withdrawal"," adalah fitur tambahan yang memungkinkan:",[241,242,244],"list",{"type":243},"info",[245,246,247,258,261],"ul",{},[248,249,250,251,254,255],"li",{},"Penarikan dana pada hari ",[212,252,253],{},"Sabtu"," dan ",[212,256,257],{},"Minggu",[248,259,260],{},"Proses transfer di luar jam kerja normal",[248,262,263],{},"Akses dana lebih cepat untuk kebutuhan mendesak",[225,265,267],{"id":266},"ketentuan-standar-vs-weekend","Ketentuan Standar vs Weekend",[269,270,271,286],"table",{},[272,273,274],"thead",{},[275,276,277,281,284],"tr",{},[278,279,280],"th",{},"Aspek",[278,282,283],{},"Settlement Standar",[278,285,238],{},[287,288,289,303,316],"tbody",{},[275,290,291,297,300],{},[292,293,294],"td",{},[212,295,296],{},"Hari Proses",[292,298,299],{},"Senin - Jumat",[292,301,302],{},"Sabtu & Minggu",[275,304,305,310,313],{},[292,306,307],{},[212,308,309],{},"Biaya Tambahan",[292,311,312],{},"Tidak ada",[292,314,315],{},"Ada biaya ekstra",[275,317,318,323,326],{},[292,319,320],{},[212,321,322],{},"Ketersediaan",[292,324,325],{},"Default",[292,327,328],{},"Fitur khusus",[217,330],{},[220,332,334],{"id":333},"mengapa-weekend-withdrawal-diperlukan","Mengapa Weekend Withdrawal Diperlukan?",[225,336,338],{"id":337},"definisi-hari-kerja","Definisi Hari Kerja",[209,340,341],{},"Berdasarkan Perjanjian Kerja Sama:",[343,344,347,349,350,353],"callout",{"color":345,"icon":346},"blue","i-lucide-info",[212,348,234],{}," adalah hari Senin sampai Jumat, ",[212,351,352],{},"tidak termasuk"," Sabtu, Minggu, dan hari libur nasional yang ditetapkan oleh Pemerintah Republik Indonesia.",[225,355,357],{"id":356}