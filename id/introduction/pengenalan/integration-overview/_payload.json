:218},"tahap-1-buat-akun-tripay","Tahap 1: Buat Akun TriPay",[209,221,222],{},"Langkah pertama adalah membuat dan memverifikasi akun TriPay. Proses pendaftaran terdiri dari dua tahap utama:",[224,225,226,254],"ol",{},[227,228,229,233],"li",{},[230,231,232],"strong",{},"Isi Formulir Pendaftaran di Halaman Depan TriPay",[234,235,236,239,242,245,248,251],"ul",{},[227,237,238],{},"Nama lengkap sesuai KTP",[227,240,241],{},"Alamat lengkap (provinsi, kabupaten, kecamatan, dst.)",[227,243,244],{},"Email aktif",[227,246,247],{},"Nomor WhatsApp aktif",[227,249,250],{},"Alamat website yang akan diintegrasikan",[227,252,253],{},"Verifikasi email dan nomor telepon",[227,255,256,259],{},[230,257,258],{},"Verifikasi Akun (5 Tahap)",[234,260,261,264,267,270,273],{},[227,262,263],{},"Pilih Jenis Akun (Personal/Bisnis)",[227,265,266],{},"Upload Dokumen sesuai jenis akun",[227,268,269],{},"Informasi Usaha (data pemilik dan bisnis)",[227,271,272],{},"Verifikasi Identitas (verifikasi wajah Privy)",[227,274,275],{},"Tanda Tangan Dokumen (PKS Privy)",[277,278,280],"h3",{"id":279},"persyaratan-dokumen","Persyaratan Dokumen",[282,283,284,297],"table",{},[285,286,287],"thead",{},[288,289,290,294],"tr",{},[291,292,293],"th",{},"Jenis Akun",[291,295,296],{},"Dokumen yang Diperlukan",[298,299,300,311],"tbody",{},[288,301,302,308],{},[303,304,305],"td",{},[230,306,307],{},"Personal",[303,309,310],{},"KTP Penanggung Jawab",[288,312,313,318],{},[303,314,315],{},[230,316,317],{},"Bisnis",[303,319,320],{},"KTP Penanggung Jawab, NPWP Penanggung Jawab, SIUP, Akta Pendirian, NPWP Perusahaan",[322,323,326,329,330,333,334,337],"callout",{"color":324,"icon":325},"blue","i-lucide-info",[230,327,328],{},"Kewajiban Data",": Mitra wajib mengisi data pendaftaran secara ",[230,331,332],{},"benar, lengkap, dan terkini",". Setiap perubahan data harus dilaporkan ke TriPay dalam waktu ",[230,335,336],{},"7 hari kalender",".",[209,339,340,341,344,345],{},"📖 ",[230,342,343],{},"Panduan Lengkap",": ",[346,347,348],"a",{"href":31},"Pendaftaran Akun",[213,350],{},[216,352,354],{"id":353},"tahap-2-ajukan-merchant","Tahap 2: Ajukan Merchant",[209,356,357],{},"Setelah akun terverifikasi, buat merchant untuk bisnis Mitra.",[277,359,361],{"id":360},"proses-pembuatan-merchant","Proses Pembuatan Merchant",[224,363,364,374,392],{},[227,365,366,369],{},[230,367,368],{},"Login ke Dashboard TriPay",[234,370,371],{},[227,372,373],{},"Akses Dashboard menggunakan email dan password",[227,375,376,379],{},[230,377,378],{},"Buat Merchant Baru",[234,380,381,386],{},[227,382,383,384],{},"Masuk ke menu ",[230,385,42],{},[227,387,388,389],{},"Klik ",[230,390,391],{},"Tambah Merchant",[227,393,394],{},[230,395,396],{},"Lengkapi Informasi Bisnis",[209,398,399],{},[230,400,401],{},"Informasi Dasar:",[282,403,404,414],{},[285,405,406],{},[288,407,408,411],{},[291,409,410],{},"Field",[291,412,413],{},"Keterangan",[298,415,416,426,436,446,456,479],{},[288,417,418,423],{},[303,419,420],{},[230,421,422],{},"Nama Merchant",[303,424,425],{},"Nama website atau aplikasi Mitra. Tidak boleh mengandung karakter spesial dan tidak boleh menggunakan nama badan usaha.",[288,427,428,433],{},[303,429,430],{},[230,431,432],{},"Kategori Bisnis",[303,434,435],{},"Pilih kategori yang sesuai dengan jenis bisnis Mitra.",[288,437,438,443],{},[303,439,440],{},[230,441,442],{},"Logo",[303,444,445],{},"Upload logo website/aplikasi (max 1MB). Format: jpg, jpeg, png. Resolusi disarankan: 200x50 pixel.",[288,447,448,453],{},[303,449,450],{},[230,451,452],{},"Deskripsi",[303,454,455],{},"Jelaskan detail produk atau layanan yang disediakan Mitra, termasuk alur transaksi dan cara transaksi pada website.",[288,457,458,463],{},[303,459,460],{},[230,461,462],{},"URL Website",[303,464,465,466,470,471,474,475,478],{},"URL website dengan format ",[467,468,469],"code",{},"https://"," atau ",[467,472,473],{},"http://",". Domain yang ",[230,476,477],{},"tidak diperbolehkan",": my.id, biz.id, xyz, vercel, netlify, blogspot, dan wordpress.",[288,480,481,486],{},[303,482,483],{},[230,484,485],{},"Data Login",[303,487,488],{},"Jika website memerlukan login untuk mengakses, isi dengan data login akun dummy untuk keperluan demo transaksi merchant.",[209,490,491],{},[230,492,493],{},"Pengaturan Teknis:",[282,495,496,504],{},[285,497,498],{},[288,499,500,502],{},[291,501,410],{},[291,503,413],{},[298,505,506,524,538],{},[288,507,508,513],{},[303,509,510],{},[230,511,512],{},"URL Callback",[303,514,515,516,470,518,520,521],{},"URL endpoint untuk menerima notifikasi transaksi. Harus mengandung domain yang sama dengan URL website. Format: ",[467,517,469],{},[467,519,473],{},". Contoh: ",[467,522,523],{},"https://example.com/callback",[288,525,526,531],{},[303,527,528],{},[230,529,530],{},"Whitelist IP",[303,532,533,534,537],{},"Alamat IPv4 dan IPv6 dari server hosting Mitra. Jika lebih dari satu, pisahkan dengan koma. Contoh: ",[467,535,536],{},"192.168.1.1,192.168.1.2",". IP dapat dilihat di panel hosting atau VPS.",[288,539,540,545],{},[303,541,542],{},[230,543,544],{},"Izinkan Inkonsistensi Nilai",[303,546,547,548,337],{},"Jika diizinkan, sistem tidak akan memvalidasi konsistensi nilai produk dengan jumlah transaksi yang masuk. Hanya ubah jika Mitra memahami fungsinya. Default: ",[230,549,550],{},"Tidak",[224,552,554,567],{"start":553},4,[227,555,556,559],{},[230,557,558],{},"Konfigurasi Channel Pembayaran",[234,560,561,564],{},[227,562,563],{},"Pilih metode pembayaran yang diinginkan",[227,565,566],{},"Atur biaya admin ke pelanggan (opsional)",[227,568,569,572],{},[230,570,571],{},"Submit dan Tunggu Verifikasi",[234,573,574,577],{},[227,575,576],{},"Tim TriPay memverifikasi dalam 1x24 jam",[227,578,579],{},"Merchant akan disetujui jika memenuhi syarat",[277,581,583],{"id":582},"metode-pembayaran-yang-tersedia","Metode Pembayaran yang Tersedia",[282,585,586,598],{},[285,587,588],{},[288,589,590,593,596],{},[291,591,592],{},"Channel",[291,594,595],{},"Biaya",[291,597,413],{},[298,599,600,611,622,633,644],{},[288,601,602,605,608],{},[303,603,604],{},"QRIS",[303,606,607],{},"0,7% + Rp750",[303,609,610],{},"Semua e-wallet dan mobile banking",[288,612,613,616,619],{},[303,614,615],{},"BCA VA",[303,617,618],{},"Rp5.500",[303,620,621],{},"Virtual Account BCA",[288,623,624,627,630],{},[303,625,626],{},"VA Lainnya",[303,628,629],{},"Rp4.250",[303,631,632],{},"BNI, BRI, Mandiri, dll",[288,634,635,638,641],{},[303,636,637],{},"E-Wallet",[303,639,640],{},"3% (min. Rp1.000)",[303,642,643],{},"GoPay, OVO, DANA, dll",[288,645,646,649,652],{},[303,647,648],{},"Retail",[303,650,651],{},"Rp3.500",[303,653,654],{},"Alfamart, Indomaret",[322,656,659,662],{"color":657,"icon":658},"amber","i-lucide-alert-triangle",[230,660,661],{},"Kategori Terlarang",": TriPay tidak menerima merchant untuk kegiatan ilegal seperti judi, pinjol ilegal, money game, perdagangan barang terlarang, dan pornografi.",[209,664,340,665,344,667],{},[230,666,343],{},[346,668,669],{"href":48},"Registrasi Merchant",[213,671],{},[216,673,675],{"id":674},"tahap-3-integrasi-dengan-bisnis","Tahap 3: Integrasi dengan Bisnis",[209,677,678],{},"Setelah merchant disetujui, Mitra akan mendapatkan kredensial untuk integrasi.",[277,680,682],{"id":681},"kredensial-yang-diperoleh","Kredensial yang Diperoleh",[282,684,685,695],{},[285,686,687],{},[288,688,689,692],{},[291,690,691],{},"Kredensial",[291,693,694],{},"Fungsi",[298,696,697,707,717],{},[288,698,699,704],{},[303,700,701],{},[230,702,703],{},"API Key",[303,705,706],{},"Identifikasi merchant dalam setiap request",[288,708,709,714],{},[303,710,711],{},[230,712,713],{},"Private Key",[303,715,716],{},"Autentikasi dan validasi signature",[288,718,719,724],{},[303,720,721],{},[230,722,723],{},"Merchant Code",[303,725,726],{},"Kode unik merchant",[322,728,730,733],{"color":657,"icon":729},"i-lucide-shield",[230,731,732],{},"Keamanan",": Simpan kredensial dengan aman. Jangan bagikan Private Key ke pihak manapun. Penggunaan kredensial oleh pihak tidak sah menjadi tanggung jawab MITRA.",[277