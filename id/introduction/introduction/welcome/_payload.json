ication/1.whatsapp-notification",{"title":112,"icon":17,"path":113,"stem":114,"children":115,"page":17},"Integrasi","/id/introduction/integrations","id/1.introduction/7.integrations",[116,120,124,128],{"title":117,"path":118,"stem":119,"icon":17},"Callback tester","/id/introduction/integrations/callback-tester","id/1.introduction/7.integrations/1.callback-tester",{"title":121,"path":122,"stem":123,"icon":17},"Sandbox","/id/introduction/integrations/sandbox","id/1.introduction/7.integrations/2.sandbox",{"title":125,"path":126,"stem":127,"icon":17},"Production","/id/introduction/integrations/production","id/1.introduction/7.integrations/3.production",{"title":129,"path":130,"stem":131,"icon":17},"Plugin","/id/introduction/integrations/plugin","id/1.introduction/7.integrations/4.plugin",{"title":133,"icon":17,"path":134,"stem":135,"children":136,"page":17},"Referral","/id/introduction/referral","id/1.introduction/8.referral",[137],{"title":133,"path":138,"stem":139,"icon":17},"/id/introduction/referral/referral","id/1.introduction/8.referral/1.referral",{"title":141,"icon":17,"path":142,"stem":143,"children":144,"page":17},"FAQs","/id/introduction/faqs","id/1.introduction/9.faqs",[145],{"title":141,"path":146,"stem":147,"icon":17},"/id/introduction/faqs/faqs","id/1.introduction/9.faqs/1.faqs",{"title":149,"path":150,"stem":151,"children":152,"page":17},"Developer Guide","/id/developer-guide","id/2.developer-guide",[153,157,161,165,169,173,177,181,185],{"title":154,"path":155,"stem":156},"Installation and Requirements","/id/developer-guide/installation-and-requirements","id/2.developer-guide/1.installation-and-requirements",{"title":158,"path":159,"stem":160},"Development Workflow","/id/developer-guide/development-workflow","id/2.developer-guide/2.development-workflow",{"title":162,"path":163,"stem":164,"icon":17},"Arsitektur Sistem","/id/developer-guide/system-architecture","id/2.developer-guide/3.system-architecture",{"title":166,"path":167,"stem":168,"icon":17},"Arsitektur Backend","/id/developer-guide/backend-architecture","id/2.developer-guide/4.backend-architecture",{"title":170,"path":171,"stem":172},"Frontend Architecture","/id/developer-guide/frontend-architecture","id/2.developer-guide/5.frontend-architecture",{"title":174,"path":175,"stem":176},"Database","/id/developer-guide/database","id/2.developer-guide/6.database",{"title":178,"path":179,"stem":180},"Coding Standard","/id/developer-guide/coding-standard","id/2.developer-guide/7.coding-standard",{"title":182,"path":183,"stem":184},"Best Practices","/id/developer-guide/best-practices","id/2.developer-guide/8.best-practices",{"title":186,"path":187,"stem":188},"Testing","/id/developer-guide/testing","id/2.developer-guide/9.testing",{"title":190,"path":191,"stem":192,"children":193,"page":17},"Api References","/id/api-references","id/3.api-references",[194,198],{"title":195,"path":196,"stem":197},"API Endpoints","/id/api-references/api-endpoints","id/3.api-references/1.api-endpoints",{"title":199,"path":200,"stem":201},"Usage Guide","/id/api-references/usage-guide","id/3.api-references/2.usage-guide",{"id":203,"title":5,"body":204,"description":875,"extension":876,"links":877,"meta":878,"navigation":879,"path":19,"seo":880,"stem":20,"__hash__":881},"docs_id/id/1.introduction/1.introduction/2.welcome.md",{"type":205,"value":206,"toc":850},"minimark",[207,211,216,231,234,237,240,244,247,252,268,272,275,279,282,296,300,308,310,314,317,377,380,382,386,390,393,404,408,411,437,441,444,464,467,471,488,492,534,538,541,570,572,576,589,592,603,606,617,619,623,697,699,703,706,741,747,749,753,827,829,833,836],[208,209,210],"p",{},"Selamat datang di TriPay Payment!",[212,213,215],"h2",{"id":214},"tentang-tripay","Tentang TriPay",[208,217,218,222,223,226,227,230],{},[219,220,221],"strong",{},"TriPay"," adalah sistem pembayaran elektronik milik ",[219,224,225],{},"PT Trijaya Digital Grup"," yang menghubungkan bisnis (merchant) dengan pelanggan melalui berbagai metode pembayaran elektronik. TriPay berperan sebagai penyelenggara sistem dan technical operator yang terhubung dengan Penyelenggara Jasa Pembayaran (PJP) yang telah memperoleh izin dari ",[219,228,229],{},"Bank Indonesia",".",[208,232,233],{},"TriPay Payment hadir sebagai jembatan yang menghubungkan bisnis atau merchant dengan pelanggan, menyediakan berbagai pilihan metode pembayaran yang lengkap, aman, dan mudah diakses melalui satu dashboard yang terintegrasi.",[208,235,236],{},"Melalui beragam pilihan integrasi API dan plugin, website atau aplikasi dapat dihubungkan dengan solusi pembayaran TriPay. Hal ini akan membantu bisnis berkembang pesat dan menjangkau pasar yang lebih luas.",[238,239],"hr",{},[212,241,243],{"id":242},"ruang-lingkup-layanan","Ruang Lingkup Layanan",[208,245,246],{},"TriPay menyediakan layanan sistem pembayaran elektronik agar MITRA dapat menerima pembayaran dari Pelanggan melalui berbagai metode pembayaran. Layanan yang disediakan meliputi:",[248,249,251],"h3",{"id":250},"_1-akses-api-dan-dashboard","1. Akses API dan Dashboard",[253,254,255,262],"ul",{},[256,257,258,261],"li",{},[219,259,260],{},"Application Programming Interface (API)",": Kumpulan fungsi, dokumentasi, dan protokol untuk integrasi sistem TriPay dengan sistem MITRA",[256,263,264,267],{},[219,265,266],{},"Dashboard TriPay",": Aplikasi berbasis web untuk pemantauan transaksi, pengaturan konfigurasi, dan pengunduhan laporan",[248,269,271],{"id":270},"_2-pemrosesan-transaksi","2. Pemrosesan Transaksi",[208,273,274],{},"Pemrosesan transaksi pembayaran dari Pelanggan ke rekening penampungan TriPay dan/atau PJP Rekanan secara real-time.",[248,276,278],{"id":277},"_3-settlement-dana","3. Settlement Dana",[208,280,281],{},"Pelimpahan Dana Transaksi kepada MITRA sesuai ketentuan:",[253,283,284,290],{},[256,285,286,289],{},[219,287,288],{},"Akun Bisnis",": H+2 (dua Hari Kerja)",[256,291,292,295],{},[219,293,294],{},"Akun Personal",": H+3 (tiga Hari Kerja)",[248,297,299],{"id":298},"_4-laporan-dan-dukungan","4. Laporan dan Dukungan",[253,301,302,305],{},[256,303,304],{},"Penyediaan laporan transaksi lengkap",[256,306,307],{},"Dukungan teknis untuk integrasi dan troubleshooting",[238,309],{},[212,311,313],{"id":312},"metode-pembayaran","Metode Pembayaran",[208,315,316],{},"TriPay menyediakan berbagai metode pembayaran (payment channel) yang lengkap:",[318,319,320,333],"table",{},[321,322,323],"thead",{},[324,325,326,330],"tr",{},[327,328,329],"th",{},"Kategori",[327,331,332],{},"Channel",[334,335,336,347,357,367],"tbody",{},[324,337,338,344],{},[339,340,341],"td",{},[219,342,343],{},"QRIS",[339,345,346],{},"Pembayaran via QR Code (dapat dibayar melalui semua e-wallet dan mobile banking)",[324,348,349,354],{},[339,350,351],{},[219,352,353],{},"Virtual Account",[339,355,356],{},"BCA, BNI, BRI, Mandiri, Permata, CIMB Niaga, dan bank lainnya",[324,358,359,364],{},[339,360,361],{},[219,362,363],{},"E-Wallet",[339,365,366],{},"GoPay, OVO, DANA, ShopeePay, LinkAja",[324,368,369,374],{},[339,370,371],{},[219,372,373],{},"Gerai Retail",[339,375,376],{},"Alfamart, Alfamidi, Indomaret",[208,378,379],{},"Semua metode pembayaran tersedia pada saat pembuatan merchant dan dapat dikonfigurasi sesuai kebutuhan bisnis.",[238,381],{},[212,383,385],{"id":384},"fitur-fitur-andalan","Fitur-fitur Andalan",[248,387,389],{"id":388},"_1-solusi-b2b-terlengkap","1. Solusi B2B Terlengkap",[208,391,392],{},"TriPay menawarkan kemudahan bagi bisnis Business-to-Business (B2B) dengan:",[253,394,395,398,401],{},[256,396,397],{},"Proses pendaftaran yang cepat dan sederhana",[256,399,400],{},"Dukungan tim khusus yang cepat tanggap",[256,402,403],{},"Dokumentasi teknis yang lengkap",[248,405,407],{"id":406},"_2-multi-channel-pembayaran","2. Multi Channel Pembayaran",[208,409,410],{},"Tersedia beragam pilihan pembayaran bagi pelanggan:",[253,412,413,419,425,431],{},[256,414,415,418],{},[219,416,417],{},"Virtual Account (VA)"," dari berbagai bank",[256,420,421,424],{},[219,422,423],{},"Transfer bank"," langsung",[256,426,427,430],{},[219,428,429],{},"Gerai retail"," (Alfamart, Indomaret)",[256,432,433,436],{},[219,434,435],{},"E-wallet"," populer di Indonesia",[248,438,440],{"id":439},"_3-notifikasi-real-time","3. Notifikasi Real-time",[208,442,443],{},"Notifikasi instan dikirimkan saat pembayaran berhasil melalui:",[253,445,446,452,458],{},[256,447,448,451],{},[219,449,450],{},"Callback/IPN"," ke server MITRA",[256,453,454,457],{},[219,455,456],{},"Email"," ke alamat yang terdaftar",[256,459,460,463],{},[219,461,462],{},"WhatsApp"," ke nomor yang terdaftar",[208,465,466],{},"Hal ini memungkinkan proses pesanan dilakukan lebih cepat dan otomatis.",[248,468,470],{"id":469},"_4-biaya-terjangkau","4. Biaya Terjangkau",[253,472,473,479,485],{},[256,474,475,476],{},"Biaya transaksi yang ",[219,477,478],{},"kompetitif dan transparan",[256,480,481,484],{},[219,482,483],{},"Tanpa biaya bulanan"," tersembunyi",[256,486,487],{},"Biaya hanya dikenakan untuk transaksi yang berhasil",[248,489,491],{"id":490},"_5-api-integrasi-lengkap","5. API & Integrasi Lengkap",[253,493,494,500,506,511],{},[256,495,496,499],{},[219,497,498],{},"Satu API"," untuk semua channel pembayaran",[256,501,502,505],{},[219,503,504],{},"Dokumentasi"," yang mudah dipahami",[256,507,508,510],{},[219,509,121],{}," untuk simulasi transaksi",[256,512,513,516,517],{},[219,514,515],{},"Plugin gratis"," untuk platform CMS populer:\n",[253,518,519,522,525,528,531],{},[256,520,521],{},"WooCommerce",[256,523,524],{},"WHMCS",[256,526,527],{},"Easy Digital Downloads",[256,529,530],{},"aMember",[256,532,533],{},"Dan lainnya",[248,535,537],{"id":536},"_6-keamanan-transaksi-anti-fraud","6. Keamanan Transaksi & Anti-fraud",[208,539,540],{},"Platform dilengkapi dengan:",[253,542,543,550,557,563],{},[256,544,545,546,549],{},"Fitur ",[219,547,548],{},"keamanan transaksi"," berlapis",[256,551,552,553,556],{},"Sistem ",[219,554,555],{},"deteksi anti-fraud"," untuk melindungi setiap transaksi",[256,558,559,562],{},[219,560,561],{},"Enkripsi data"," untuk menjaga kerahasiaan informasi",[256,564,565,566,569],{},"Kepatuhan terhadap regulasi ",[219,567,568],{},"APU PPT"," (Anti Pencucian Uang dan Pencegahan Pendanaan Terorisme)",[238,571],{},[212,573,575],{"id":574},"posisi-tripay-dalam-sistem-pembayaran","Posisi TriPay dalam Sistem Pembayaran",[577,578,581,584,585,588],"callout",{"color":579,"icon":580},"blue","i-lucide-info",[219,582,583],{},"Penting untuk Dipahami",": TriPay bukan Penyelenggara Jasa Pembayaran (PJP) yang memiliki izin langsung dari Bank Indonesia. TriPay menjalankan peran sebagai ",[219,586,587],{},"penyelenggara sistem dan technical operator"," yang terhubung dengan PJP Rekanan berizin.",[208,590,591],{},"Struktur kerja sama:",[593,594,599],"pre",{"className":595,"code":597,"language":598},[596],"language-text","Pelanggan → Metode Pembayaran → PJP Rekanan (Berizin BI) → TriPay → MITRA\n","text",[600,601,597],"code",{"__ignoreMap":602},"",[208,604,605],{},"Dengan struktur ini, TriPay memastikan:",[253,607,608,611,614],{},[256,609,610],{},"Seluruh transaksi diproses melalui PJP yang telah berizin Bank Indonesia",[256,612,613],{},"Kepatuhan terhadap peraturan perundang-undangan di bidang sistem pembayaran",[256,615,616],{},"Perlindungan dana MITRA dan Pelanggan",[238,618],{},[212,620,622],{"id":621},"keunggulan-menggunakan-tripay","Keunggulan Menggunakan TriPay",[318,624,625,635],{},[321,626,627],{},[324,628,629,632],{},[327,630,631],{},"Aspek",[327,633,634],{},"Keunggulan",[334,636,637,647,657,667,677,687],{},[324,638,639,644],{},[339,640,641],{},[219,642,643],{},"Kemudahan",[339,645,646],{},"Satu dashboard untuk semua channel pembayaran",[324,648,649,654],{},[339,650,651],{},[219,652,653],{},"Kecepatan",[339,655,656],{},"Integrasi cepat dengan API yang sederhana",[324,658,659,664],{},[339,660,661],{},[219,662,663],{},"Kelengkapan",[339,665,666],{},"Semua metode pembayaran populer tersedia",[324,668,669,674],{},[339,670,671],{},[219,672,673],{},"Transparansi",[339,675,676],{},"Biaya jelas tanpa hidden cost",[324,678,679,684],{},[339,680,681],{},[219,682,683],{},"Keamanan",[339,685,686],{},"Terhubung dengan PJP berizin Bank Indonesia",[324,688,689,694],{},[339,690,691],{},[219,692,693],{},"Dukungan",[339,695,696],{},"Tim support yang responsif",[238,698],{},[212,700,702],{"id":701},"mulai-menggunakan-tripay","Mulai Menggunakan TriPay",[208,704,705],{},"Untuk memulai menggunakan layanan TriPay, ikuti langkah-langkah berikut:",[707,708,709,718,726,734],"ol",{},[256,710,711,717],{},[219,712,713],{},[714,715,716],"a",{"href":30},"Daftar Akun"," - Buat akun TriPay dan verifikasi identitas",[256,719,720,725],{},[219,721,722],{},[714,723,724],{"href":47},"Buat Merchant"," - Ajukan merchant untuk bisnis Mitra",[256,727,728,733],{},[219,729,730],{},[714,731,732],{"href":51},"Aktivasi Channel"," - Pilih metode pembayaran yang diinginkan",[256,735,736,740],{},[219,737,738],{},[714,739,112],{"href":122}," - Integrasikan dengan website atau aplikasi",[208,742,743,744,746],{},"Atau baca halaman ",[714,745,14],{"href":15}," untuk gambaran singkat proses integrasi.",[238,748],{},[212,750,752],{"id":751},"informasi-perusahaan","Informasi Perusahaan",[318,754,755,765],{},[321,756,757],{},[324,758,759,762],{},[327,760,761],{},"Data",[327,763,764],{},"Keterangan",[334,766,767,776,785,795,805,815],{},[324,768,769,774],{},[339,770,771],{},[219,772,773],{},"Nama Perusahaan",[339,775,225],{},[324,777,778,783],{},[339,779,780],{},[219,781,782],{},"Nama Layanan",[339,784,221],{},[324,786,787,792],{},[339,788,789],{},[219,790,791],{},"Direktur",[339,793,794],{},"Tri Hariyanto",[324,796,797,802],{},[339,798,799],{},[219,800,801],{},"Alamat",[339,803,804],{},"Dusun Ngompak 2 RT 003/RW 003, Desa Cepoko, Kec. Ngrambe, Kab. Ngawi, Jawa Timur",[324,806,807,812],{},[339,808,809],{},[219,810,811],{},"Telepon/WhatsApp",[339,813,814],{},"085730000727",[324,816,817,821],{},[339,818,819],{},[219,820,456],{},[339,822,823],{},[714,824,826],{"href":825},"mailto:ops@trihariyanto.com","ops@trihariyanto.com",[238,828],{},[212,830,832],{"id":831},"referensi-hukum","Referensi Hukum",[208,834,835],{},"Seluruh pemanfaatan layanan TriPay tunduk pada:",[253,837,838,841,844,847],{},[256,839,840],{},"Peraturan perundang-undangan di bidang sistem pembayaran",[256,842,843],{},"Ketentuan Anti Pencucian Uang dan Pencegahan Pendanaan Terorisme (APU PPT)",[256,845,846],{},"Peraturan perlindungan konsumen",[256,848,849],{},"Ketentuan otoritas terkait lainnya yang berlaku di Indonesia",{"title":602,"searchDepth":851,"depth":851,"links":852},2,[853,854,861,862,870,871,872,873,874],{"id":214,"depth":851,"text":215},{"id":242,"depth":851,"text":243,"children":855},[856,858,859,860],{"id":250,"depth":857,"text":251},3,{"id":270,"depth":857,"text":271},{"id":277,"depth":857,"text":278},{"id":298,"depth":857,"text":299},{"id":312,"depth":851,"text":313},{"id":384,"depth":851,"text":385,"children":863},[864,865,866,867,868,869],{"id":388,"depth":857,"text":389},{"id":406,"depth":857,"text":407},{"id":439,"depth":857,"text":440},{"id":469,"depth":857,"text":470},{"id":490,"depth":857,"text":491},{"id":536,"depth":857,"text":537},{"id":574,"depth":851,"text":575},{"id":621,"depth":851,"text":622},{"id":701,"depth":851,"text":702},{"id":751,"depth":851,"text":752},{"id":831,"depth":851,"text":832},"Pengenalan layanan sistem pembayaran elektronik TriPay","md",null,{},{"icon":17},{"title":5,"description":875},"a-Dqchrv0zTL5LeyS4aYnFwpTqqewV6H3aCRKIK5s9g",[883,885],{"title":14,"path":15,"stem":16,"description":884,"icon":17,"children":-1},"Gambaran umum proses integrasi dengan layanan TriPay",{"title":14,"path":15,"stem":22,"description":884,"icon":17,"children":-1},1766367450971]