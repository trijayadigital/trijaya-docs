,1008,1009],{},"Lakukan Tanda Tangan Digital",[429,1011,1012,1015,1018],{},[423,1013,1014],{},"Klik tombol untuk melakukan tanda tangan",[423,1016,1017],{},"Ikuti instruksi yang muncul di layar",[423,1019,1020],{},"Pastikan tanda tangan dilakukan dengan benar",[423,1022,1023,1026],{},[252,1024,1025],{},"Konfirmasi Tanda Tangan",[429,1027,1028,1031],{},[423,1029,1030],{},"Setelah tanda tangan selesai, sistem akan mengirimkan konfirmasi",[423,1032,1033],{},"Simpan dokumen PKS yang sudah ditandatangani",[397,1035,1038,1040],{"color":1036,"icon":1037},"green","i-lucide-file-check",[252,1039,580],{},": Tanda tangan digital memiliki kekuatan hukum yang sama dengan tanda tangan basah. Pastikan Mitra telah membaca dan memahami seluruh isi PKS sebelum menandatangani.",[223,1042,1044],{"id":1043},"proses-verifikasi-oleh-admin","Proses Verifikasi oleh Admin",[208,1046,1047],{},"Setelah semua tahap verifikasi selesai:",[420,1049,1050,1067],{},[423,1051,1052,1055],{},[252,1053,1054],{},"Tunggu Review oleh Admin",[429,1056,1057,1064],{},[423,1058,1059,1060,1063],{},"Tim TriPay akan memproses verifikasi dalam ",[252,1061,1062],{},"1x24 jam"," (hari kerja)",[423,1065,1066],{},"Mitra akan menerima notifikasi via email atau WhatsApp",[423,1068,1069,1072],{},[252,1070,1071],{},"Status Verifikasi",[429,1073,1074,1077],{},[423,1075,1076],{},"Jika disetujui: Akun akan aktif dan Mitra dapat menggunakan semua fitur TriPay",[423,1078,1079],{},"Jika ditolak: Mitra akan menerima alasan penolakan dan dapat memperbaiki data/dokumen yang kurang",[397,1081,1083,1086,1087,1089],{"color":399,"icon":1082},"i-lucide-clock",[252,1084,1085],{},"Estimasi Waktu",": Proses verifikasi akun biasanya memakan waktu ",[252,1088,1062],{}," (hari kerja). Jika lebih dari 2 hari kerja belum ada kabar, hubungi customer support.",[212,1091],{},[215,1093,1095],{"id":1094},"ketentuan-know-your-customer-kyc","Ketentuan Know Your Customer (KYC)",[208,1097,1098,1099,1102],{},"Proses verifikasi akun TriPay mengikuti ketentuan ",[252,1100,1101],{},"Know Your Customer (KYC)"," sesuai regulasi yang berlaku.",[223,1104,1106],{"id":1105},"tujuan-kyc","Tujuan KYC",[1108,1109,1111],"list",{"type":1110},"info",[429,1112,1113,1116,1119,1129],{},[423,1114,1115],{},"Memastikan identitas Mitra yang mendaftar adalah valid",[423,1117,1118],{},"Mencegah penyalahgunaan layanan untuk kegiatan ilegal",[423,1120,1121,1122,1125,1126],{},"Memenuhi ketentuan ",[252,1123,1124],{},"Anti Pencucian Uang (APU)"," dan ",[252,1127,1128],{},"Pencegahan Pendanaan Terorisme (PPT)",[423,1130,1131],{},"Melindungi Mitra dan Pelanggan dari fraud",[223,1133,1135],{"id":1134},"kewajiban-mitra","Kewajiban Mitra",[208,1137,1138],{},"Berdasarkan Perjanjian Kerja Sama, Mitra wajib:",[420,1140,1141,1147,1153],{},[423,1142,1143,1146],{},[252,1144,1145],{},"Mematuhi ketentuan KYC"," yang ditetapkan TriPay dan/atau PJP Rekanan",[423,1148,1149,1152],{},[252,1150,1151],{},"Memberikan informasi tambahan"," apabila diminta untuk keperluan verifikasi",[423,1154,1155,1158,1159,1162],{},[252,1156,1157],{},"Melaporkan perubahan data"," dalam waktu ",[252,1160,1161],{},"7 (tujuh) Hari Kalender"," sejak perubahan terjadi",[223,1164,1166],{"id":1165},"data-yang-wajib-dilaporkan-jika-berubah","Data yang Wajib Dilaporkan Jika Berubah",[228,1168,1169,1178],{},[231,1170,1171],{},[234,1172,1173,1175],{},[237,1174,239],{},[237,1176,1177],{},"Batas Waktu Pelaporan",[244,1179,1180,1188,1195,1202,1209,1216],{},[234,1181,1182,1185],{},[249,1183,1184],{},"Alamat tempat usaha",[249,1186,1187],{},"7 hari kalender",[234,1189,1190,1193],{},[249,1191,1192],{},"Nomor telepon/WhatsApp",[249,1194,1187],{},[234,1196,1197,1200],{},[249,1198,1199],{},"Alamat email",[249,1201,1187],{},[234,1203,1204,1207],{},[249,1205,1206],{},"Rekening bank tujuan settlement",[249,1208,1187],{},[234,1210,1211,1214],{},[249,1212,1213],{},"Susunan pengurus (untuk Akun Bisnis)",[249,1215,1187],{},[234,1217,1218,1221],{},[249,1219,1220],{},"Jenis usaha",[249,1222,1187],{},[397,122