er-guide/3.system-architecture",{"title":168,"path":169,"stem":170,"icon":16},"Arsitektur Backend","/id/developer-guide/backend-architecture","id/2.developer-guide/4.backend-architecture",{"title":172,"path":173,"stem":174},"Frontend Architecture","/id/developer-guide/frontend-architecture","id/2.developer-guide/5.frontend-architecture",{"title":176,"path":177,"stem":178},"Database","/id/developer-guide/database","id/2.developer-guide/6.database",{"title":180,"path":181,"stem":182},"Coding Standard","/id/developer-guide/coding-standard","id/2.developer-guide/7.coding-standard",{"title":184,"path":185,"stem":186},"Best Practices","/id/developer-guide/best-practices","id/2.developer-guide/8.best-practices",{"title":188,"path":189,"stem":190},"Testing","/id/developer-guide/testing","id/2.developer-guide/9.testing",{"title":192,"path":193,"stem":194,"children":195,"page":16},"Api References","/id/api-references","id/3.api-references",[196,200],{"title":197,"path":198,"stem":199},"API Endpoints","/id/api-references/api-endpoints","id/3.api-references/1.api-endpoints",{"title":201,"path":202,"stem":203},"Usage Guide","/id/api-references/usage-guide","id/3.api-references/2.usage-guide",{"id":205,"title":27,"body":206,"description":333,"extension":334,"links":333,"meta":335,"navigation":336,"path":28,"seo":337,"stem":29,"__hash__":338},"docs_id/id/1.introduction/2.account/1.registration.md",{"type":207,"value":208,"toc":325},"minimark",[209,213,218,221,237,241,297,301,304],[210,211,212],"p",{},"Untuk mulai menggunakan layanan Tripay, perlu membuat akun terlebih dahulu. Proses pendaftaran mudah dan cepat. Berikut panduan langkah demi langkah pendaftaran.",[214,215,217],"h3",{"id":216},"persyaratan-pendaftaran","Persyaratan Pendaftaran",[210,219,220],{},"Sebelum mendaftar, pastikan telah menyiapkan:",[222,223,224,228,231,234],"ul",{},[225,226,227],"li",{},"Alamat email aktif yang akan digunakan untuk administrasi akun.",[225,229,230],{},"Nomor WhatsApp aktif untuk administrasi akun dan notifikasi.",[225,232,233],{},"Data diri seperti KTP untuk proses verifikasi.",[225,235,236],{},"Alamat website yang akan diintegrasikan dengan layanan Tripay.",[214,238,240],{"id":239},"langkah-langkah-pendaftaran-akun","Langkah-langkah Pendaftaran Akun",[242,243,244,252,259,294],"ol",{},[225,245,246,247,251],{},"Kunjungi website resmi Tripay di ",[248,249,250],"strong",{},"tripay.co.id",".",[225,253,254,255,258],{},"Klik tombol ",[248,256,257],{},"Daftar"," untuk menuju halaman pendaftaran.",[225,260,261,262],{},"Isi formulir pendaftaran dengan data yang benar dan valid:\n",[222,263,264,270,276,282,288],{},[225,265,266,269],{},[248,267,268],{},"Nama Lengkap:"," Masukkan nama lengkap sesuai KTP.",[225,271,272,275],{},[248,273,274],{},"Alamat:"," Isi dengan alamat domisili.",[225,277,278,281],{},[248,279,280],{},"Email:"," Masukkan alamat email aktif.",[225,283,284,287],{},[248,285,286],{},"Nomor HP:"," Masukkan nomor WhatsApp yang aktif.",[225,289,290,293],{},[248,291,292],{},"Alamat Website:"," Masukkan URL website yang ingin didaftarkan.",[225,295,296],{},"Setelah semua data terisi, selesaikan proses pendaftaran sesuai instruksi.",[214,298,300],{"id":299},"aktivasi-dan-verifikasi-akun","Aktivasi dan Verifikasi Akun",[210,302,303],{},"Setelah akun berhasil dibuat, langkah selanjutnya adalah aktivasi. Akun yang terverifikasi dapat menggunakan seluruh fitur Tripay tanpa batasan.",[242,305,306,309,312,322],{},[225,307,308],{},"Login ke dashboard akun.",[225,310,311],{},"Masuk ke menu verifikasi akun.",[225,313,314,315,318,319,251],{},"Unggah (upload) dokumen yang diperlukan: seperti ",[248,316,317],{},"KTP"," dan ",[248,320,321],{},"foto diri",[225,323,324],{},"Tim Tripay akan segera memproses verifikasi data dalam 1x24 jam.",{"title":326,"searchDepth":327,"depth":327,"links":328},"",2,[329,331,332],{"id":216,"depth":330,"text":217},3,{"id":239,"depth":330,"text":240},{"id":299,"depth":330,"text":300},null,"md",{},{"icon":16},{"title":27,"description":333},"50a8wUURzIgbjgg42zrVA6mitJK-cWYR-wihRNEiFRA",[340,341],{"title":18,"path":19,"stem":20,"description":333,"icon":16,"children":-1},{"title":31,"path":32,"stem":33,"description":342,"icon":16,"children":-1},"Tripay menyediakan dua jenis akun: Akun Personal dan Akun Bisnis. Setiap pengguna dapat melakukan upgrade dari akun personal ke akun bisnis sesuai kebutuhan bisnis masing-masing. Proses upgrade bersifat permanen dan tidak dapat dikembalikan (downgrade) ke akun personal.",1761632150952]