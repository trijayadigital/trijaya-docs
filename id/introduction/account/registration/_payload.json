53,1009,1010],{},"Lakukan Tanda Tangan Digital",[430,1012,1013,1016,1019],{},[424,1014,1015],{},"Klik tombol untuk melakukan tanda tangan",[424,1017,1018],{},"Ikuti instruksi yang muncul di layar",[424,1020,1021],{},"Pastikan tanda tangan dilakukan dengan benar",[424,1023,1024,1027],{},[253,1025,1026],{},"Konfirmasi Tanda Tangan",[430,1028,1029,1032],{},[424,1030,1031],{},"Setelah tanda tangan selesai, sistem akan mengirimkan konfirmasi",[424,1033,1034],{},"Simpan dokumen PKS yang sudah ditandatangani",[398,1036,1039,1041],{"color":1037,"icon":1038},"green","i-lucide-file-check",[253,1040,581],{},": Tanda tangan digital memiliki kekuatan hukum yang sama dengan tanda tangan basah. Pastikan Mitra telah membaca dan memahami seluruh isi PKS sebelum menandatangani.",[224,1043,1045],{"id":1044},"proses-verifikasi-oleh-admin","Proses Verifikasi oleh Admin",[209,1047,1048],{},"Setelah semua tahap verifikasi selesai:",[421,1050,1051,1068],{},[424,1052,1053,1056],{},[253,1054,1055],{},"Tunggu Review oleh Admin",[430,1057,1058,1065],{},[424,1059,1060,1061,1064],{},"Tim TriPay akan memproses verifikasi dalam ",[253,1062,1063],{},"1x24 jam"," (hari kerja)",[424,1066,1067],{},"Mitra akan menerima notifikasi via email atau WhatsApp",[424,1069,1070,1073],{},[253,1071,1072],{},"Status Verifikasi",[430,1074,1075,1078],{},[424,1076,1077],{},"Jika disetujui: Akun akan aktif dan Mitra dapat menggunakan semua fitur TriPay",[424,1079,1080],{},"Jika ditolak: Mitra akan menerima alasan penolakan dan dapat memperbaiki data/dokumen yang kurang",[398,1082,1084,1087,1088,1090],{"color":400,"icon":1083},"i-lucide-clock",[253,1085,1086],{},"Estimasi Waktu",": Proses verifikasi akun biasanya memakan waktu ",[253,1089,1063],{}," (hari kerja). Jika lebih dari 2 hari kerja belum ada kabar, hubungi customer support.",[213,1092],{},[216,1094,1096],{"id":1095},"ketentuan-know-your-customer-kyc","Ketentuan Know Your Customer (KYC)",[209,1098,1099,1100,1103],{},"Proses verifikasi akun TriPay mengikuti ket