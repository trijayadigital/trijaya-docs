.system-architecture",{"title":168,"path":169,"stem":170,"icon":16},"Arsitektur Backend","/id/developer-guide/backend-architecture","id/2.developer-guide/4.backend-architecture",{"title":172,"path":173,"stem":174},"Frontend Architecture","/id/developer-guide/frontend-architecture","id/2.developer-guide/5.frontend-architecture",{"title":176,"path":177,"stem":178},"Database","/id/developer-guide/database","id/2.developer-guide/6.database",{"title":180,"path":181,"stem":182},"Coding Standard","/id/developer-guide/coding-standard","id/2.developer-guide/7.coding-standard",{"title":184,"path":185,"stem":186},"Best Practices","/id/developer-guide/best-practices","id/2.developer-guide/8.best-practices",{"title":188,"path":189,"stem":190},"Testing","/id/developer-guide/testing","id/2.developer-guide/9.testing",{"title":192,"path":193,"stem":194,"children":195,"page":16},"Api References","/id/api-references","id/3.api-references",[196,200],{"title":197,"path":198,"stem":199},"API Endpoints","/id/api-references/api-endpoints","id/3.api-references/1.api-endpoints",{"title":201,"path":202,"stem":203},"Usage Guide","/id/api-references/usage-guide","id/3.api-references/2.usage-guide",{"id":205,"title":31,"body":206,"description":399,"extension":400,"links":401,"meta":402,"navigation":403,"path":32,"seo":404,"stem":33,"__hash__":405},"docs_id/id/1.introduction/2.account/2.upgrade.md",{"type":207,"value":208,"toc":384},"minimark",[209,222,227,230,235,249,253,279,283,287,299,303,326,330,359,363],[210,211,212,213,217,218,221],"p",{},"Tripay menyediakan dua jenis akun: ",[214,215,216],"strong",{},"Akun Personal"," dan ",[214,219,220],{},"Akun Bisnis",". Setiap pengguna dapat melakukan upgrade dari akun personal ke akun bisnis sesuai kebutuhan bisnis masing-masing. Proses upgrade bersifat permanen dan tidak dapat dikembalikan (downgrade) ke akun personal.",[223,224,226],"h2",{"id":225},"perbedaan-akun-personal-dan-akun-bisnis","Perbedaan Akun Personal dan Akun Bisnis",[210,228,229],{},"Perbedaan utama antara kedua jenis akun terletak pada:",[231,232,234],"h3",{"id":233},"rekening-penarikan","Rekening Penarikan",[236,237,238,244],"ul",{},[239,240,241,243],"li",{},[214,242,216],{},": Hanya dapat menggunakan rekening atas nama pribadi.",[239,245,246,248],{},[214,247,220],{},": Dapat menggunakan rekening perusahaan (PT/CV) atau rekening pribadi direktur/penanggung jawab.",[231,250,252],{"id":251},"masa-kliring","Masa Kliring",[236,254,255,260],{},[239,256,257,259],{},[214,258,216],{},": Masa kliring standar H+3 (3x24 jam).",[239,261,262,264,265],{},[214,263,220],{},": Dapat memperoleh masa kliring H+2 (2x24 jam) dengan memenuhi syarat berikut:\n",[236,266,267,270,273,276],{},[239,268,269],{},"Minimum 30 transaksi sukses",[239,271,272],{},"Total nilai transaksi minimum Rp 30.000.000",[239,274,275],{},"Umur akun minimum 60 hari sejak transaksi pertama",[239,277,278],{},"Berlaku untuk QRIS dan semua Virtual Account (VA), kecuali BCA yang tetap H+3",[223,280,282],{"id":281},"persyaratan-dokumen","Persyaratan Dokumen",[231,284,286],{"id":285},"dokumen-untuk-akun-personal","Dokumen untuk Akun Personal",[288,289,290,293,296],"ol",{},[239,291,292],{},"KTP",[239,294,295],{},"Foto selfie memegang KTP",[239,297,298],{},"Foto selfie memegang kertas putih bertuliskan \"Verifikasi Akun TriPay (Nomor HP)\" beserta tanda tangan",[231,300,302],{"id":301},"dokumen-untuk-akun-bisnis","Dokumen untuk Akun Bisnis",[288,304,305,308,311,314,317,320,323],{},[239,306,307],{},"KTP direktur/penanggung jawab",[239,309,310],{},"Foto selfie direktur/penanggung jawab memegang KTP",[239,312,313],{},"Foto selfie direktur/penanggung jawab memegang kertas putih bertuliskan \"Verifikasi Akun TriPay (Nomor HP)\" beserta tanda tangan",[239,315,316],{},"NPWP direktur/penanggung jawab",[239,318,319],{},"NPWP PT/CV",[239,321,322],{},"SIUP (Surat Izin Usaha Perdagangan) yang diterbitkan oleh Gubernur setempat",[239,324,325],{},"Akta Pendirian PT/CV yang diterbitkan oleh KEMENKUMHAM RI",[223,327,329],{"id":328},"langkah-langkah-upgrade-akun","Langkah-langkah Upgrade Akun",[288,331,332,335,342,347,350,353,356],{},[239,333,334],{},"Login ke dashboard Tripay.",[239,336,337,338,341],{},"Masuk ke menu ",[214,339,340],{},"Pengaturan",".",[239,343,344,345,341],{},"Pilih ",[214,346,31],{},[239,348,349],{},"Pilih jenis akun yang diinginkan (Personal atau Bisnis).",[239,351,352],{},"Unggah semua dokumen yang diperlukan sesuai dengan jenis akun yang dipilih.",[239,354,355],{},"Submit permintaan upgrade.",[239,357,358],{},"Tim Tripay akan memproses verifikasi dokumen dalam waktu 1x24 jam.",[223,360,362],{"id":361},"catatan-penting","Catatan Penting",[236,364,365,371,378,381],{},[239,366,367,368,341],{},"Proses upgrade akun ",[214,369,370],{},"tidak dikenakan biaya",[239,372,373,374,377],{},"Setelah akun berhasil di-upgrade ke akun bisnis, ",[214,375,376],{},"tidak dapat dikembalikan"," (downgrade) ke akun personal.",[239,379,380],{},"Pastikan semua dokumen yang diunggah jelas, valid, dan sesuai dengan ketentuan yang berlaku.",[239,382,383],{},"Masa kliring H+2 untuk akun bisnis akan otomatis aktif setelah memenuhi syarat yang ditentukan.",{"title":385,"searchDepth":386,"depth":386,"links":387},"",2,[388,393,397,398],{"id":225,"depth":386,"text":226,"children":389},[390,392],{"id":233,"depth":391,"text":234},3,{"id":251,"depth":391,"text":252},{"id":281,"depth":386,"text":282,"children":394},[395,396],{"id":285,"depth":391,"text":286},{"id":301,"depth":391,"text":302},{"id":328,"depth":386,"text":329},{"id":361,"depth":386,"text":362},"Tripay menyediakan dua jenis akun: Akun Personal dan Akun Bisnis. Setiap pengguna dapat melakukan upgrade dari akun personal ke akun bisnis sesuai kebutuhan bisnis masing-masing. Proses upgrade bersifat permanen dan tidak dapat dikembalikan (downgrade) ke akun personal.","md",null,{},{"icon":16},{"title":31,"description":399},"DeuaBnNi2byiMax0vBTMdbsCQB6Xautcs6rZWu_kjuo",[407,408],{"title":27,"path":28,"stem":29,"description":401,"icon"