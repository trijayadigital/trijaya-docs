9,226,227,231],{},[228,229,230],"strong",{},"TriPay"," adalah layanan payment gateway yang membantu merchant menerima pembayaran online dari berbagai channel (Virtual Account, QRIS, E-Wallet, Retail) melalui satu integrasi.",[221,233,235],{"id":234},"apakah-tripay-merupakan-bank-atau-e-wallet","Apakah TriPay merupakan Bank atau E-Wallet?",[209,237,238,241,242,245],{},[228,239,240],{},"Tidak."," TriPay adalah ",[228,243,244],{},"Operator Teknologi"," yang bekerja sama dengan Penyedia Jasa Pembayaran (PJP) Rekanan untuk memfasilitasi transaksi. TriPay tidak menyimpan dana nasabah.",[221,247,249],{"id":248},"siapa-yang-bisa-menggunakan-tripay","Siapa yang bisa menggunakan TriPay?",[251,252,253,257,260,263],"ul",{},[254,255,256],"li",{},"Pemilik bisnis online (e-commerce, marketplace)",[254,258,259],{},"Developer yang membutuhkan payment gateway",[254,261,262],{},"Penyedia layanan digital",[254,264,265],{},"Semua pelaku usaha yang memerlukan pembayaran online",[213,267],{},[216,269,271],{"id":270},"pendaftaran-akun","Pendaftaran & Akun",[221,273,275],{"id":274},"bagaimana-cara-mendaftar-di-tripay","Bagaimana cara mendaftar di TriPay?",[277,278,279,282,292,295,298,301],"ol",{},[254,280,281],{},"Kunjungi website TriPay",[254,283,284,285,288,289],{},"Klik ",[228,286,287],{},"Daftar"," atau ",[228,290,291],{},"Register",[254,293,294],{},"Isi data diri dan bisnis",[254,296,297],{},"Verifikasi email",[254,299,300],{},"Lengkapi KYC (upload KTP dan selfie)",[254,302,303],{},"Tunggu approval",[221,305,307],{"id":306},"berapa-lama-proses-verifikasi-akun","Berapa lama proses verifikasi akun?",[209,309,310,311,314],{},"Proses verifikasi biasanya memakan waktu ",[228,312,313],{},"1-3 Hari Kerja"," setelah dokumen lengkap disubmit.",[221,316,318],{"id":317},"apa-bedanya-akun-personal-dan-akun-bisnis","Apa bedanya Akun Personal dan Akun Bisnis?",[320,321,322,338],"table",{},[323,324,325],"thead",{},[326,327,328,332,335],"tr",{},[329,330,331],"th",{},"Aspek",[329,333,334],{},"Akun Personal",[329,336,337],{},"Akun Bisnis",[339,340,341,355,368],"tbody",{},[326,342,343,349,352],{},[344,345,346],"td",{},[228,347,348],{},"Rekening Penarikan",[344,350,351],{},"Atas nama pribadi",[344,353,354],{},"Atas nama perusahaan atau direktur",[326,356,357,362,365],{},[344,358,359],{},[228,360,361],{},"Settlement",[344,363,364],{},"H+3",[344,366,367],{},"H+2 (setelah memenuhi syarat)",[326,369,370,375,378],{},[344,371,372],{},[228,373,374],{},"Dokumen",[344,376,377],{},"KTP",[344,379,380],{},"KTP + Dokumen perusahaan",[221,382,384],{"id":383},"bagaimana-cara-upgrade-ke-akun-bisnis","Bagaimana cara upgrade ke Akun Bisnis?",[277,386,387,390,399,402],{},[254,388,389],{},"Login ke Dashboard",[254,391,392,393,396,397],{},"Masuk ke ",[228,394,395],{},"Pengaturan"," → ",[228,398,34],{},[254,400,401],{},"Lengkapi dokumen yang diperlukan",[254,403,404],{},"Submit dan tunggu verifikasi",[213,406],{},[216,408,42],{"id":409},"merchant",[221,411,413],{"id":412},"bagaimana-cara-membuat-merchant-baru","Bagaimana cara membuat Merchant baru?",[277,415,416,418,423,428,431,434],{},[254,417,389],{},[254,419,420,421],{},"Masuk ke menu ",[228,422,42],{},[254,424,284,425],{},[228,426,427],{},"Tambah Merchant",[254,429,430],{},"Isi informasi merchant",[254,432,433],{},"Pilih channel pembayaran",[254,435,436],{},"Submit untuk review",[221,438,440],{"id":439},"berapa-lama-approval-merchant","Berapa lama approval Merchant?",[209,442,443,444,446],{},"Approval merchant biasanya ",[228,445,313],{},".",[221,448,450],{"id":449},"bisakah-memiliki-lebih-dari-satu-merchant","Bisakah memiliki lebih dari satu Merchant?",[209,452,453,456],{},[228,454,455],{},"Ya."," Satu akun dapat memiliki beberapa merchant untuk bisnis yang berbeda.",[213,458],{},[216,460,55],{"id":461},"transaksi",[221,463,465],{"id":464},"channel-pembayaran-apa-saja-yang-tersedia","Channel pembayaran apa saja yang tersedia?",[320,467,468,478],{},[323,469,470],{},[326,471,472,475],{},[329,473,474],{},"Kategori",[329,476,477],{},"Ch