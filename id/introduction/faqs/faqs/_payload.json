,225,226,230],{},[227,228,229],"strong",{},"TriPay"," adalah layanan payment gateway yang membantu merchant menerima pembayaran online dari berbagai channel (Virtual Account, QRIS, E-Wallet, Retail) melalui satu integrasi.",[220,232,234],{"id":233},"apakah-tripay-merupakan-bank-atau-e-wallet","Apakah TriPay merupakan Bank atau E-Wallet?",[208,236,237,240,241,244],{},[227,238,239],{},"Tidak."," TriPay adalah ",[227,242,243],{},"Operator Teknologi"," yang bekerja sama dengan Penyedia Jasa Pembayaran (PJP) Rekanan untuk memfasilitasi transaksi. TriPay tidak menyimpan dana nasabah.",[220,246,248],{"id":247},"siapa-yang-bisa-menggunakan-tripay","Siapa yang bisa menggunakan TriPay?",[250,251,252,256,259,262],"ul",{},[253,254,255],"li",{},"Pemilik bisnis online (e-commerce, marketplace)",[253,257,258],{},"Developer yang membutuhkan payment gateway",[253,260,261],{},"Penyedia layanan digital",[253,263,264],{},"Semua pelaku usaha yang memerlukan pembayaran online",[212,266],{},[215,268,270],{"id":269},"pendaftaran-akun","Pendaftaran & Akun",[220,272,274],{"id":273},"bagaimana-cara-mendaftar-di-tripay","Bagaimana cara mendaftar di TriPay?",[276,277,278,281,291,294,297,300],"ol",{},[253,279,280],{},"Kunjungi website TriPay",[253,282,283,284,287,288],{},"Klik ",[227,285,286],{},"Daftar"," atau ",[227,289,290],{},"Register",[253,292,293],{},"Isi data diri dan bisnis",[253,295,296],{},"Verifikasi email",[253,298,299],{},"Lengkapi KYC (upload KTP dan selfie)",[253,301,302],{},"Tunggu approval",[220,304,306],{"id":305},"berapa-lama-proses-verifikasi-akun","Berapa lama proses verifikasi akun?",[208,308,309,310,313],{},"Proses verifikasi biasanya memakan waktu ",[227,311,312],{},"1-3 Hari Kerja"," setelah dokumen lengkap disubmit.",[220,315,317],{"id":316},"apa-bedanya-akun-personal-dan-akun-bisnis","Apa bedanya Akun Personal dan Akun Bisnis?",[319,320,321,337],"table",{},[322,323,324],"thead",{},[325,326,327,331,334],"tr",{},[328,329,330],"th",{},"Aspek",[328,332,333],{},"Akun Perso