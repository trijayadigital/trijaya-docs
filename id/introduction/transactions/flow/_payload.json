girim callback ke server MITRA\n        ↓\n7. MITRA update status pesanan\n        ↓\n8. Pelanggan menerima konfirmasi\n","text",[229,230,226],"code",{"__ignoreMap":231},"",[217,233,235],{"id":234},"status-transaksi","Status Transaksi",[237,238,239,252],"table",{},[240,241,242],"thead",{},[243,244,245,249],"tr",{},[246,247,248],"th",{},"Status",[246,250,251],{},"Keterangan",[253,254,255,267,277,287,297],"tbody",{},[243,256,257,264],{},[258,259,260],"td",{},[261,262,263],"strong",{},"UNPAID",[258,265,266],{},"Menunggu pembayaran",[243,268,269,274],{},[258,270,271],{},[261,272,273],{},"PAID",[258,275,276],{},"Pembayaran berhasil",[243,278,279,284],{},[258,280,281],{},[261,282,283],{},"EXPIRED",[258,285,286],{},"Waktu pembayaran habis",[243,288,289,294],{},[258,290,291],{},[261,292,293],{},"FAILED",[258,295,296],{},"Pembayaran gagal",[243,298,299,304],{},[258,300,301],{},[261,302,303],{},"REFUND",[258,305,306],{},"Dana dikembalikan",{"title":231,"searchDepth":308,"depth":308,"links":309},2,[310],{"id":210,"depth":308,"text":211,"children":311},[312,314],{"id":219,"depth":313,"text":220},3,{"id":234,"depth":313,"text":235},"Mekanisme dan alur transaksi di TriPay","md",null,{},{"icon":17},{"title":59,"description":315},"cxKqohVDX5XbBG-mXUl34ibSqm18s9w-A1SOLKyprUs",[323,325],{"title":50,"path":51,"stem":52,"description":324,"icon":17,"children":-1},"Panduan lengkap metode pembayaran yang tersedia di TriPay",{"title":63,"path":64,"stem":65,"description":326,"icon":17,"children":-1},"Panduan lengkap proses kliring dan settlement dana transaksi TriPay",1766367454363]