ngirim callback ke server MITRA\n        ↓\n7. MITRA update status pesanan\n        ↓\n8. Pelanggan menerima konfirmasi\n","text",[230,231,227],"code",{"__ignoreMap":232},"",[218,234,236],{"id":235},"status-transaksi","Status Transaksi",[238,239,240,253],"table",{},[241,242,243],"thead",{},[244,245,246,250],"tr",{},[247,248,249],"th",{},"Status",[247,251,252],{},"Keterangan",[254,255,256,268,278,288,298],"tbody",{},[244,257,258,265],{},[259,260,261],"td",{},[262,263,264],"strong",{},"UNPAID",[259,266,267],{},"Menunggu pembayaran",[244,269,270,275],{},[259,271,272],{},[262,273,274],{},"PAID",[259,276,277],{},"Pembayaran berhasil",[244,279,280,285],{},[259,281,282],{},[262,283,284],{},"EXPIRED",[259,286,287],{},"Waktu pembayaran habis",[244,289,290,295],{},[259,291,292],{},[262,293,294],{},"FAILED",[259,296,297],{},"Pembayaran gagal",[244,299,300,305],{},[259,301,302],{},[262,303,304],{},"REFUND",[259,306,307],{},"Dana dikembalikan",{"title":232,"searchDepth":309,"depth":309,"links":310},2,[311],{"id":211,"depth":309,"text":212,"children":312},[313,315],{"id":220,"depth":314,"text":221},3,{"id":235,"depth":314,"text":236},"Mekanisme dan alur transaksi di TriPay","md",null,{},{"icon":17},{"title":60,"description":316},"cxKqohVDX5XbBG-mXUl34ibSqm18s9w-A1SOLKyprUs",[324,326],{"title":51,"path":52,"stem":53,"description":325,"icon":17,"children":-1},"Panduan lengkap metode pembayaran yang tersedia di TriPay",{"title":64,"path":65,"stem":66,"description":327,"icon":17,"children":-1},"Panduan lengkap proses kliring dan settlement dana transaksi TriPay",1772610232059]