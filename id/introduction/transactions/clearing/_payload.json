rsitektur Backend","/id/developer-guide/backend-architecture","id/2.developer-guide/4.backend-architecture",{"title":171,"path":172,"stem":173},"Frontend Architecture","/id/developer-guide/frontend-architecture","id/2.developer-guide/5.frontend-architecture",{"title":175,"path":176,"stem":177},"Database","/id/developer-guide/database","id/2.developer-guide/6.database",{"title":179,"path":180,"stem":181},"Coding Standard","/id/developer-guide/coding-standard","id/2.developer-guide/7.coding-standard",{"title":183,"path":184,"stem":185},"Best Practices","/id/developer-guide/best-practices","id/2.developer-guide/8.best-practices",{"title":187,"path":188,"stem":189},"Testing","/id/developer-guide/testing","id/2.developer-guide/9.testing",{"title":191,"path":192,"stem":193,"children":194,"page":17},"Api References","/id/api-references","id/3.api-references",[195,199],{"title":196,"path":197,"stem":198},"API Endpoints","/id/api-references/api-endpoints","id/3.api-references/1.api-endpoints",{"title":200,"path":201,"stem":202},"Usage Guide","/id/api-references/usage-guide","id/3.api-references/2.usage-guide",{"id":204,"title":64,"body":205,"description":856,"extension":857,"links":858,"meta":859,"navigation":860,"path":65,"seo":861,"stem":66,"__hash__":862},"docs_id/id/1.introduction/4.transactions/2.clearing.md",{"type":206,"value":207,"toc":826},"minimark",[208,215,218,223,234,266,268,272,277,284,288,299,301,305,309,320,344,348,394,406,408,412,415,419,473,477,512,520,522,526,530,570,574,582,584,588,592,690,695,697,701,712,748,750,754,758,765,767,771,809,811,815],[209,210,211,214],"p",{},[212,213,64],"strong",{}," merupakan proses yang dibutuhkan oleh sistem untuk menjamin transaksi yang terjadi bebas dari adanya fraud maupun hal lain yang dapat menimbulkan kerugian layanan TriPay Payment. Halaman ini menjelaskan secara lengkap mekanisme, jadwal, dan ketentuan kliring di TriPay.",[216,217],"hr",{},[219,220,222],"h2",{"id":221},"apa-itu-kliring","Apa itu Kliring?",[209,224,225,226,229,230,233],{},"Kliring adalah proses verifikasi dan validasi transaksi yang telah diselesaikan oleh pelanggan sebelum dana dapat ditarik ke rekening Mitra. Masa kliring adalah ",[212,227,228],{},"3x24 jam (tiga hari kerja)"," untuk akun Personal dan ",[212,231,232],{},"2x24 jam (dua hari kerja)"," untuk akun Bisnis. Proses ini bertujuan untuk:",[235,236,238],"list",{"type":237},"success",[239,240,241,248,254,260],"ul",{},[242,243,244,247],"li",{},[212,245,246],{},"Mencegah fraud"," dan kecurangan dalam transaksi",[242,249,250,253],{},[212,251,252],{},"Melindungi"," Mitra dan Pelanggan dari kerugian",[242,255,256,259],{},[212,257,258],{},"Memastikan keamanan"," dan validitas setiap transaksi",[242,261,262,265],{},[212,263,264],{},"Menjaga integritas"," sistem pembayaran TriPay",[216,267],{},[219,269,271],{"id":270},"mekanisme-kliring","Mekanisme Kliring",[273,274,276],"h3",{"id":275},"proses-otomatis","Proses Otomatis",[209,278,279,280,283],{},"Setiap transaksi yang telah diselesaikan pelanggan akan memasuki proses kliring ",[212,281,282],{},"secara otomatis",". Tidak ada tindakan manual yang diperlukan dari Mitra.",[273,285,287],{"id":286},"alur-proses-kliring","Alur Proses Kliring",[289,290,295],"pre",{"className":291,"code":293,"language":294},[292],"language-text","1. Pelanggan Melakukan Pembayaran\n              ↓\n2. Transaksi Berstatus DIBAYAR (PAID)\n              ↓\n3. Transaksi Masuk ke Proses Kliring (Otomatis)\n              ↓\n4. Verifikasi dan Validasi Transaksi\n              ↓\n5. Proses Kliring Selesai (3x24 jam Hari Kerja)\n              ↓\n6. Saldo Tersedia untuk Ditarik ke Rekening Mitra\n","text",[296,297,293],"code",{"__ignoreMap":298},"",[216,300],{},[219,302,304],{"id":303},"waktu-kliring","Waktu Kliring",[273,306,308],{"id":307},"ketentuan-umum","Ketentuan Umum",[209,310,311,312,315,316,319],{},"Proses kliring membutuhkan waktu ",[212,313,314],{},"3x24 jam"," (tiga hari kerja) sejak transaksi berstatus ",[212,317,318],{},"dibayar",", dengan ketentuan:",[235,321,323],{"type":322},"info",[239,324,325,331,338,341],{},[242,326,327,330],{},[212,328,329],{},"Tidak termasuk"," hari Sabtu, Minggu, dan tanggal merah (hari libur nasional)",[242,332,333,334,337],{},"Waktu kliring dihitung berdasarkan ",[212,335,336],{},"Hari Kerja"," saja",[242,339,340],{},"Jika jatuh pada hari libur, proses kliring dilanjutkan pada Hari Kerja berikutnya",[242,342,343],{},"Batas waktu lain dapat ditentukan oleh pengelola sesuai kondisi",[273,345,347],{"id":346},"hari-kerja-vs-hari-kalender","Hari Kerja vs Hari Kalender",[349,350,351,364],"table",{},[352,353,354],"thead",{},[355,356,357,361],"tr",{},[358,359,360],"th",{},"Istilah",[358,362,363],{},"Definisi",[365,366,367,381],"tbody",{},[355,368,369,374],{},[370,371,372],"td",{},[212,373,336],{},[370,375,376,377,380],{},"Senin sampai Jumat, ",[212,378,379],{},"tidak termasuk"," Sabtu, Minggu, dan hari libur nasional",[355,382,383,388],{},[370,384,385],{},[212,386,387],{},"Hari Kalender",[370,389,390,391],{},"Semua hari dalam satu bulan kalender ",[212,392,393],{},"tanpa kecuali",[395,396,399,402,403,405],"callout",{"color":397,"icon":398},"blue","i-lucide-info",[212,400,401],{},"Penting",": Waktu kliring dihitung berdasarkan ",[212,404,336],{},", bukan Hari Kalender. Jika proses kliring jatuh pada hari libur, proses dilanjutkan pada Hari Kerja berikutnya.",[216,407],{},[219,409,411],{"id":410},"masa-waktu-kliring-yang-berbeda","Masa Waktu Kliring yang Berbeda",[209,413,414],{},"Mitra dapat memperoleh masa waktu kliring yang berbeda yang disesuaikan dengan kondisi atau tingkat risiko pada layanan Mitra.",[273,416,418],{"id":417},"faktor-yang-mempengaruhi-waktu-kliring","Faktor yang Mempengaruhi Waktu Kliring",[349,420,421,431],{},[352,422,423],{},[355,424,425,428],{},[358,426,427],{},"Faktor",[358,429,430],{},"Keterangan",[365,432,433,443,453,463],{},[355,434,435,440],{},[370,436,437],{},[212,438,439],{},"Tingkat Risiko",[370,441,442],{},"Mitra dengan risiko rendah dapat memperoleh waktu kliring lebih cepat",[355,444,445,450],{},[370,446,447],{},[212,448,449],{},"Riwayat Transaksi",[370,451,452],{},"Mitra dengan riwayat transaksi baik dapat memperoleh waktu kliring lebih cepat",[355,454,455,460],{},[370,456,457],{},[212,458,459],{},"Volume Transaksi",[370,461,462],{},"Mitra dengan volume transaksi tinggi dan konsisten dapat memperoleh waktu kliring lebih cepat",[355,464,465,470],{},[370,466,467],{},[212,468,469],{},"Kepatuhan",[370,471,472],{},"Mitra yang patuh terhadap ketentuan dapat memperoleh waktu kliring lebih cepat",[273,474,476],{"id":475},"waktu-kliring-standar","Waktu Kliring Standar",[349,478,479,488],{},[352,480,481],{},[355,482,483,486],{},[358,484,485],{},"Kondisi",[358,487,304],{},[365,489,490,502],{},[355,491,492,497],{},[370,493,494],{},[212,495,496],{},"Default",[370,498,499,501],{},[212,500,314],{}," (tiga Hari Kerja)",[355,503,504,509],{},[370,505,506],{},[212,507,508],{},"Setelah Evaluasi",[370,510,511],{},"Dapat disesuaikan sesuai kondisi dan tingkat risiko Mitra",[395,513,516,519],{"color":514,"icon":515},"amber","i-lucide-alert-triangle",[212,517,518],{},"Catatan",": Waktu kliring dapat berbeda untuk setiap Mitra tergantung evaluasi dari pengelola. Batas waktu lain dapat ditentukan oleh pengelola sesuai kondisi.",[216,521],{},[219,523,525],{"id":524},"status-saldo-selama-kliring","Status Saldo Selama Kliring",[273,527,529],{"id":528},"saldo-pending-vs-saldo-tersedia","Saldo Pending vs Saldo Tersedia",[349,531,532,541],{},[352,533,534],{},[355,535,536,539],{},[358,537,538],{},"Status Saldo",[358,540,430],{},[365,542,543,556],{},[355,544,545,550],{},[370,546,547],{},[212,548,549],{},"Saldo Pending",[370,551,552,553],{},"Saldo yang masih dalam proses kliring, ",[212,554,555],{},"belum dapat ditarik",[355,557,558,563],{},[370,559,560],{},[212,561,562],{},"Saldo Tersedia",[370,564,565,566,569],{},"Saldo yang sudah selesai proses kliring, ",[212,567,568],{},"dapat ditarik"," ke rekening Mitra",[273,571,573],{"id":572},"ketentuan-penarikan","Ketentuan Penarikan",[395,575,576,578,579,581],{"color":514,"icon":515},[212,577,401],{},": Saldo Mitra yang masih berada pada proses kliring ",[212,580,555],{}," ke rekening Mitra hingga proses kliring selesai. Hanya saldo yang sudah selesai proses kliring (Saldo Tersedia) yang dapat ditarik.",[216,583],{},[219,585,587],{"id":586},"contoh-perhitungan-jadwal-kliring","Contoh Perhitungan Jadwal Kliring",[273,589,591],{"id":590},"waktu-kliring-3x24-jam-hari-kerja","Waktu Kliring 3x24 Jam (Hari Kerja)",[349,593,594,607],{},[352,595,596],{},[355,597,598,601,604],{},[358,599,600],{},"Transaksi Dibayar",[358,602,603],{},"Hari",[358,605,606],{},"Kliring Selesai",[365,608,609,623,635,647,657,667,679],{},[355,610,611,614,617],{},[370,612,613],{},"Senin",[370,615,616],{},"Kerja",[370,618,619,622],{},[212,620,621],{},"Kamis"," (3 Hari Kerja)",[355,624,625,628,630],{},[370,626,627],{},"Selasa",[370,629,616],{},[370,631,632,622],{},[212,633,634],{},"Jumat",[355,636,637,640,642],{},[370,638,639],{},"Rabu",[370,641,616],{},[370,643,644,646],{},[212,645,613],{}," (minggu berikutnya, 3 Hari Kerja)",[355,648,649,651,653],{},[370,650,621],{},[370,652,616],{},[370,654,655,646],{},[212,656,627],{},[355,658,659,661,663],{},[370,660,634],{},[370,662,616],{},[370,664,665,646],{},[212,666,639],{},[355,668,669,672,675],{},[370,670,671],{},"Sabtu",[370,673,674],{},"Libur",[370,676,677,646],{},[212,678,639],{},[355,680,681,684,686],{},[370,682,683],{},"Minggu",[370,685,674],{},[370,687,688,646],{},[212,689,639],{},[395,691,692,694],{"color":397,"icon":398},[212,693,518],{},": Transaksi yang dibayar pada hari Sabtu atau Minggu akan mulai dihitung proses kliringnya pada Hari Kerja berikutnya (Senin).",[216,696],{},[219,698,700],{"id":699},"kondisi-penundaan-kliring","Kondisi Penundaan Kliring",[209,702,703,704,707,708,711],{},"TriPay berhak ",[212,705,706],{},"menunda proses kliring"," atau ",[212,709,710],{},"menahan sementara"," dana transaksi dalam kondisi:",[235,713,715],{"type":714},"warning",[239,716,717,724,730,736,742],{},[242,718,719,720,723],{},"Indikasi ",[212,721,722],{},"fraud"," atau kecurangan",[242,725,726,729],{},[212,727,728],{},"Dispute/Chargeback"," dari Pelanggan atau PJP Rekanan",[242,731,732,735],{},[212,733,734],{},"Permintaan dari otoritas"," berwenang",[242,737,738,741],{},[212,739,740],{},"Pelanggaran"," Perjanjian Kerja Sama",[242,743,744,747],{},[212,745,746],{},"Transaksi mencurigakan"," yang memerlukan investigasi lebih lanjut",[216,749],{},[219,751,753],{"id":752},"rekonsiliasi","Rekonsiliasi",[273,755,757],{"id":756},"kewajiban","Kewajiban",[209,759,760,761,764],{},"Mitra wajib melakukan rekonsiliasi dan menyampaikan koreksi ",[212,762,763],{},"paling lambat H+7 Hari Kalender"," setelah tanggal transaksi.",[216,766],{},[219,768,770],{"id":769},"dukungan","Dukungan",[349,772,773,783],{},[352,774,775],{},[355,776,777,780],{},[358,778,779],{},"Channel",[358,781,782],{},"Kontak",[365,784,785,799],{},[355,786,787,792],{},[370,788,789],{},[212,790,791],{},"Email",[370,793,794],{},[795,796,798],"a",{"href":797},"mailto:ops@trihariyanto.com","ops@trihariyanto.com",[355,800,801,806],{},[370,802,803],{},[212,804,805],{},"WhatsApp",[370,807,808],{},"085730000727",[216,810],{},[219,812,814],{"id":813},"referensi","Referensi",[209,816,817,818,821,822,825],{},"Ketentuan settlement berdasarkan ",[212,819,820],{},"Pasal 9"," dan ",[212,823,824],{},"Lampiran III"," Perjanjian Kerja Sama.",{"title":298,"searchDepth":827,"depth":827,"links":828},2,[829,830,835,839,843,847,850,851,854,855],{"id":221,"depth":827,"text":222},{"id":270,"depth":827,"text":271,"children":831},[832,834],{"id":275,"depth":833,"text":276},3,{"id":286,"depth":833,"text":287},{"id":303,"depth":827,"text":304,"children":836},[837,838],{"id":307,"depth":833,"text":308},{"id":346,"depth":833,"text":347},{"id":410,"depth":827,"text":411,"children":840},[841,842],{"id":417,"depth":833,"text":418},{"id":475,"depth":833,"text":476},{"id":524,"depth":827,"text":525,"children":844},[845,846],{"id":528,"depth":833,"text":529},{"id":572,"depth":833,"text":573},{"id":586,"depth":827,"text":587,"children":848},[849],{"id":590,"depth":833,"text":591},{"id":699,"depth":827,"text":700},{"id":752,"depth":827,"text":753,"children":852},[853],{"id":756,"depth":833,"text":757},{"id":769,"depth":827,"text":770},{"id":813,"depth":827,"text":814},"Panduan lengkap proses kliring dan settlement dana transaksi TriPay","md",null,{},{"icon":17},{"title":64,"description":856},"brwUeTiy7JoVPEnL3JFq-QOemIVgN3UZUVQUhAJQzKQ",[864,866],{"title":60,"path":61,"stem":62,"description":865,"icon":17,"children":-1},"Mekanisme dan alur transaksi di TriPay",{"title":68,"path":69,"stem":70,"description":867,"icon":17,"children":-1},"Skema diskon fee transaksi TriPay",1766371210553]