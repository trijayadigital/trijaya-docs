n/6.notification/1.whatsapp-notification",{"title":113,"icon":17,"path":114,"stem":115,"children":116,"page":17},"Integrasi","/id/introduction/integrations","id/1.introduction/7.integrations",[117,121,125,129],{"title":118,"path":119,"stem":120,"icon":17},"Callback tester","/id/introduction/integrations/callback-tester","id/1.introduction/7.integrations/1.callback-tester",{"title":122,"path":123,"stem":124,"icon":17},"Sandbox","/id/introduction/integrations/sandbox","id/1.introduction/7.integrations/2.sandbox",{"title":126,"path":127,"stem":128,"icon":17},"Production","/id/introduction/integrations/production","id/1.introduction/7.integrations/3.production",{"title":130,"path":131,"stem":132,"icon":17},"Plugin","/id/introduction/integrations/plugin","id/1.introduction/7.integrations/4.plugin",{"title":134,"icon":17,"path":135,"stem":136,"children":137,"page":17},"Referral","/id/introduction/referral","id/1.introduction/8.referral",[138],{"title":134,"path":139,"stem":140,"icon":17},"/id/introduction/referral/referral","id/1.introduction/8.referral/1.referral",{"title":142,"icon":17,"path":143,"stem":144,"children":145,"page":17},"FAQs","/id/introduction/faqs","id/1.introduction/9.faqs",[146],{"title":142,"path":147,"stem":148,"icon":17},"/id/introduction/faqs/faqs","id/1.introduction/9.faqs/1.faqs",{"title":150,"path":151,"stem":152,"children":153,"page":17},"Developer Guide","/id/developer-guide","id/2.developer-guide",[154,158,162,166,170,174,178,182,186],{"title":155,"path":156,"stem":157},"Installation and Requirements","/id/developer-guide/installation-and-requirements","id/2.developer-guide/1.installation-and-requirements",{"title":159,"path":160,"stem":161},"Development Workflow","/id/developer-guide/development-workflow","id/2.developer-guide/2.development-workflow",{"title":163,"path":164,"stem":165,"icon":17},"Arsitektur Sistem","/id/developer-guide/system-architecture","id/2.developer-guide/3.system-architecture",{"title":167,"path":168,"stem":169,"icon":17},"Arsitektur Backend","/id/developer-guide/backend-architecture","id/2.developer-guide/4.backend-architecture",{"title":171,"path":172,"stem":173},"Frontend Architecture","/id/developer-guide/frontend-architecture","id/2.developer-guide/5.frontend-architecture",{"title":175,"path":176,"stem":177},"Database","/id/developer-guide/database","id/2.developer-guide/6.database",{"title":179,"path":180,"stem":181},"Coding Standard","/id/developer-guide/coding-standard","id/2.developer-guide/7.coding-standard",{"title":183,"path":184,"stem":185},"Best Practices","/id/developer-guide/best-practices","id/2.developer-guide/8.best-practices",{"title":187,"path":188,"stem":189},"Testing","/id/developer-guide/testing","id/2.developer-guide/9.testing",{"title":191,"path":192,"stem":193,"children":194,"page":17},"Api References","/id/api-references","id/3.api-references",[195,199],{"title":196,"path":197,"stem":198},"API Endpoints","/id/api-references/api-endpoints","id/3.api-references/1.api-endpoints",{"title":200,"path":201,"stem":202},"Usage Guide","/id/api-references/usage-guide","id/3.api-references/2.usage-guide",{"id":204,"title":167,"body":205,"description":1426,"extension":1427,"links":1428,"meta":1429,"navigation":1430,"path":168,"seo":1431,"stem":169,"__hash__":1432},"docs_id/id/2.developer-guide/4.backend-architecture.md",{"type":206,"value":207,"toc":1391},"minimark",[208,225,232,237,240,292,296,301,304,309,324,328,331,336,341,366,371,390,395,409,413,416,421,426,443,448,464,469,483,488,502,506,509,513,530,535,540,556,561,577,582,596,605,609,612,616,630,635,655,660,686,691,717,724,728,731,735,752,757,789,794,825,832,836,839,844,858,863,907,911,914,919,1028,1032,1036,1046,1063,1067,1073,1099,1103,1109,1132,1136,1140,1160,1164,1172,1176,1184,1188,1196,1199,1203,1219,1223,1240,1244,1261,1265,1282,1286,1336,1340,1384,1388],[209,210,211,212,216,217,220,221,224],"p",{},"Aplikasi TriPay mengikuti ",[213,214,215],"strong",{},"arsitektur monolithic"," yang dibangun di atas ",[213,218,219],{},"framework Laravel"," dengan ",[213,222,223],{},"Vue.js"," untuk interaktivitas frontend. Arsitektur ini menggabungkan pola tradisional MVC (Model-View-Controller) dengan komponen frontend modern dan service layer untuk pemisahan concern yang lebih baik.",[209,226,227],{},[228,229],"img",{"alt":230,"src":231},"Arsitektur Laravel","/images/laravel-architecture.png",[233,234,236],"h2",{"id":235},"gambaran-arsitektur","Gambaran Arsitektur",[209,238,239],{},"Sistem diorganisir ke dalam lapisan-lapisan yang berbeda, masing-masing dengan tanggung jawab spesifik:",[241,242,243,250,256,262,268,274,280,286],"ol",{},[244,245,246,249],"li",{},[213,247,248],{},"Browser Layer"," - User interface yang diakses melalui web browser",[244,251,252,255],{},[213,253,254],{},"Router Layer"," - Routing dan distribusi request",[244,257,258,261],{},[213,259,260],{},"View Layer"," - Presentasi frontend (Blade + Vue.js)",[244,263,264,267],{},[213,265,266],{},"Controller Layer"," - Orkestrasi business logic",[244,269,270,273],{},[213,271,272],{},"Service Layer"," - Business logic kompleks dan integrasi eksternal",[244,275,276,279],{},[213,277,278],{},"Model Layer"," - Akses dan manipulasi data",[244,281,282,285],{},[213,283,284],{},"Database Layer"," - Persistensi data (MySQL)",[244,287,288,291],{},[213,289,290],{},"Third-Party Services"," - Integrasi API eksternal",[233,293,295],{"id":294},"detail-komponen","Detail Komponen",[297,298,300],"h3",{"id":299},"_1-browser","1. Browser",[209,302,303],{},"Titik masuk di mana pengguna berinteraksi dengan aplikasi melalui web browser. Semua HTTP request berasal dari sini dan response di-render kembali ke pengguna.",[209,305,306],{},[213,307,308],{},"Tanggung Jawab:",[310,311,312,315,318,321],"ul",{},[244,313,314],{},"Menampilkan user interface",[244,316,317],{},"Menangkap interaksi pengguna",[244,319,320],{},"Mengirim HTTP request ke server",[244,322,323],{},"Merender response dari server",[297,325,327],{"id":326},"_2-router","2. Router",[209,329,330],{},"Sistem routing Laravel yang bertindak sebagai pengontrol lalu lintas untuk semua request yang masuk.",[209,332,333],{},[213,334,335],{},"Dua Jenis Route:",[209,337,338],{},[213,339,340],{},"a. Route to Pages (Vue Router)",[310,342,343,346,349,352],{},[244,344,345],{},"Menangani navigasi frontend",[244,347,348],{},"Mengarahkan request ke layer View untuk merender halaman",[244,350,351],{},"Digunakan untuk halaman user-facing (dashboard, transaksi, pengaturan, dll.)",[244,353,354,355,359,360,359,363],{},"Contoh: ",[356,357,358],"code",{},"/dashboard",", ",[356,361,362],{},"/transactions",[356,364,365],{},"/profile",[209,367,368],{},[213,369,370],{},"b. Route to Controller",[310,372,373,376,379,382],{},[244,374,375],{},"Menangani API request dan form submission",[244,377,378],{},"Mengarahkan request ke Controller untuk diproses",[244,380,381],{},"Digunakan untuk manipulasi data dan business logic",[244,383,354,384,359,387],{},[356,385,386],{},"/api/transaction/create",[356,388,389],{},"/api/merchant/update",[209,391,392],{},[213,393,394],{},"File Konfigurasi:",[310,396,397,403],{},[244,398,399,402],{},[356,400,401],{},"routes/web.php"," - Web routes untuk halaman",[244,404,405,408],{},[356,406,407],{},"routes/api.php"," - API routes untuk operasi data",[297,410,412],{"id":411},"_3-view-blade-vue","3. View (Blade + Vue)",[209,414,415],{},"Layer presentasi yang menggabungkan Laravel Blade templating dengan komponen Vue.js.",[209,417,418],{},[213,419,420],{},"Komponen:",[209,422,423],{},[213,424,425],{},"a. Blade Templates",[310,427,428,431,434,437],{},[244,429,430],{},"Template engine di sisi server",[244,432,433],{},"Merender struktur HTML awal",[244,435,436],{},"Menyediakan struktur layout dan konten SEO-friendly",[244,438,439,440],{},"Terletak di ",[356,441,442],{},"resources/views/",[209,444,445],{},[213,446,447],{},"b. Vue.js Components",[310,449,450,453,456,459],{},[244,451,452],{},"Interaktivitas di sisi client",[244,454,455],{},"Update UI dinamis tanpa reload halaman",[244,457,458],{},"Komponen frontend yang reusable",[244,460,439,461],{},[356,462,463],{},"resources/js/components/",[209,465,466],{},[213,467,468],{},"Alur Data:",[310,470,471,477],{},[244,472,473,476],{},[213,474,475],{},"Send data",": Controller mengirim data ke View untuk rendering",[244,478,479,482],{},[213,480,481],{},"Send input from FE",": View mengirim input pengguna kembali ke Controller",[209,484,485],{},[213,486,487],{},"Fitur Utama:",[310,489,490,493,496,499],{},[244,491,492],{},"Hot Module Replacement (HMR) untuk development",[244,494,495],{},"Arsitektur berbasis komponen",[244,497,498],{},"Reactive data binding",[244,500,501],{},"Pengalaman Single Page Application (SPA)",[297,503,505],{"id":504},"_4-controller","4. Controller",[209,507,508],{},"Orkestrator yang menangani HTTP request, memproses business logic, dan mengkoordinasikan antar layer yang berbeda.",[209,510,511],{},[213,512,308],{},[310,514,515,518,521,524,527],{},[244,516,517],{},"Menerima dan memvalidasi request",[244,519,520],{},"Mengimplementasikan business logic",[244,522,523],{},"Berinteraksi dengan Model untuk operasi data",[244,525,526],{},"Memanggil layer Service untuk operasi kompleks",[244,528,529],{},"Mengembalikan response ke View atau API client",[209,531,532],{},[213,533,534],{},"Jenis Controller:",[209,536,537],{},[213,538,539],{},"a. Web Controllers",[310,541,542,545,548],{},[244,543,544],{},"Menangani request rendering halaman",[244,546,547],{},"Mengembalikan view dengan data",[244,549,354,550,359,553],{},[356,551,552],{},"DashboardController",[356,554,555],{},"TransactionController",[209,557,558],{},[213,559,560],{},"b. API Controllers",[310,562,563,566,569],{},[244,564,565],{},"Menangani API request",[244,567,568],{},"Mengembalikan JSON response",[244,570,354,571,359,574],{},[356,572,573],{},"API\\TransactionController",[356,575,576],{},"API\\MerchantController",[209,578,579],{},[213,580,581],{},"Best Practices:",[310,583,584,587,590,593],{},[244,585,586],{},"Jaga controller tetap ringan",[244,588,589],{},"Delegasikan logic kompleks ke Service",[244,591,592],{},"Gunakan Form Request class untuk validasi",[244,594,595],{},"Ikuti prinsip single responsibility",[209,597,598,601,602],{},[213,599,600],{},"Lokasi:"," ",[356,603,604],{},"app/Http/Controllers/",[297,606,608],{"id":607},"_5-service","5. Service",[209,610,611],{},"Layer khusus untuk business logic kompleks dan integrasi layanan eksternal.",[209,613,614],{},[213,615,308],{},[310,617,618,621,624,627],{},[244,619,620],{},"Mengenkapsulasi business rule yang kompleks",[244,622,623],{},"Menangani integrasi API pihak ketiga",[244,625,626],{},"Menyediakan business logic yang reusable di berbagai controller",[244,628,629],{},"Mengelola komunikasi dengan layanan eksternal",[209,631,632],{},[213,633,634],{},"Use Cases:",[310,636,637,640,643,646,649,652],{},[244,638,639],{},"Integrasi payment provider",[244,641,642],{},"Email service (Amazon SES)",[244,644,645],{},"WhatsApp notification service",[244,647,648],{},"Analytics tracking",[244,650,651],{},"Verifikasi KYC (Verihubs, Gemini)",[244,653,654],{},"File storage (Amazon S3)",[209,656,657],{},[213,658,659],{},"Keuntungan:",[310,661,662,668,674,680],{},[244,663,664,667],{},[213,665,666],{},"Separation of Concerns",": Business logic terpisah dari controller",[244,669,670,673],{},[213,671,672],{},"Reusability",": Service dapat digunakan di berbagai controller",[244,675,676,679],{},[213,677,678],{},"Testability",": Lebih mudah test logic kompleks secara terpisah",[244,681,682,685],{},[213,683,684],{},"Maintainability",": Logic terpusat untuk update yang lebih mudah",[209,687,688],{},[213,689,690],{},"Contoh Services:",[310,692,693,699,705,711],{},[244,694,695,698],{},[356,696,697],{},"PaymentProviderService"," - Menangani API payment provider",[244,700,701,704],{},[356,702,703],{},"NotificationService"," - Kirim email, SMS, WhatsApp",[244,706,707,710],{},[356,708,709],{},"TransactionService"," - Pemrosesan transaksi kompleks",[244,712,713,716],{},[356,714,715],{},"WebhookService"," - Menangani webhook yang masuk",[209,718,719,601,721],{},[213,720,600],{},[356,722,723],{},"app/Services/",[297,725,727],{"id":726},"_6-model","6. Model",[209,729,730],{},"Layer data yang merepresentasikan tabel database dan menangani operasi data menggunakan Eloquent ORM Laravel.",[209,732,733],{},[213,734,308],{},[310,736,737,740,743,746,749],{},[244,738,739],{},"Mendefinisikan struktur tabel database",[244,741,742],{},"Mengimplementasikan relasi data",[244,744,745],{},"Menangani query dan mutasi data",[244,747,748],{},"Mendefinisikan aturan validasi data",[244,750,751],{},"Mengimplementasikan business logic terkait data",[209,753,754],{},[213,755,756],{},"Fitur:",[310,758,759,765,771,777,783],{},[244,760,761,764],{},[213,762,763],{},"Eloquent ORM",": Object-Relational Mapping untuk operasi database",[244,766,767,770],{},[213,768,769],{},"Relationships",": Definisi relasi antar tabel (hasMany, belongsTo, dll.)",[244,772,773,776],{},[213,774,775],{},"Scopes",": Query constraint yang reusable",[244,778,779,782],{},[213,780,781],{},"Accessors/Mutators",": Transform data saat retrieve atau save",[244,784,785,788],{},[213,786,787],{},"Events",": Trigger aksi pada lifecycle event model",[209,790,791],{},[213,792,793],{},"Model Umum:",[310,795,796,802,807,813,819],{},[244,797,798,801],{},[356,799,800],{},"User"," - Akun pengguna",[244,803,804,806],{},[356,805,42],{}," - Informasi merchant",[244,808,809,812],{},[356,810,811],{},"Transaction"," - Transaksi pembayaran",[244,814,815,818],{},[356,816,817],{},"Channel"," - Channel pembayaran",[244,820,821,824],{},[356,822,823],{},"Withdrawal"," - Request penarikan dana",[209,826,827,601,829],{},[213,828,600],{},[356,830,831],{},"app/Models/",[297,833,835],{"id":834},"_7-database-mysql","7. Database (MySQL)",[209,837,838],{},"Layer persistensi di mana semua data aplikasi disimpan.",[209,840,841],{},[213,842,843],{},"Struktur Database:",[310,845,846,849,852,855],{},[244,847,848],{},"Relational database management system",[244,850,851],{},"Menyimpan data user, transaksi, pengaturan, log",[244,853,854],{},"Menjamin integritas dan konsistensi data",[244,856,857],{},"Menangani concurrent access",[209,859,860],{},[213,861,862],{},"Tabel Utama:",[310,864,865,871,877,883,889,895,901],{},[244,866,867,870],{},[356,868,869],{},"users"," - Akun pengguna dan autentikasi",[244,872,873,876],{},[356,874,875],{},"merchants"," - Profil dan konfigurasi merchant",[244,878,879,882],{},[356,880,881],{},"transactions"," - Record transaksi pembayaran",[244,884,885,888],{},[356,886,887],{},"channels"," - Channel pembayaran yang tersedia",[244,890,891,894],{},[356,892,893],{},"withdrawals"," - Riwayat penarikan dana",[244,896,897,900],{},[356,898,899],{},"fees"," - Konfigurasi biaya transaksi",[244,902,903,906],{},[356,904,905],{},"logs"," - Log sistem dan aktivitas",[297,908,910],{"id":909},"_8-third-party-services","8. Third-Party Services",[209,912,913],{},"Layanan eksternal yang terintegrasi ke dalam aplikasi untuk fungsionalitas tambahan.",[209,915,916],{},[213,917,918],{},"Layanan Terintegrasi:",[241,920,921,937,950,963,976,989,1002,1015],{},[244,922,923,926],{},[213,924,925],{},"Payment Providers",[310,927,928,931,934],{},[244,929,930],{},"BCA, BNI, Neo, NOBU, Prismalink",[244,932,933],{},"DurianPay, LinkQu, Esmartlink, PakaiLink",[244,935,936],{},"Tujuan: Proses pembayaran dan settlement",[244,938,939,942],{},[213,940,941],{},"Email Service",[310,943,944,947],{},[244,945,946],{},"Amazon SES",[244,948,949],{},"Tujuan: Pengiriman email transaksional",[244,951,952,955],{},[213,953,954],{},"Storage Service",[310,956,957,960],{},[244,958,959],{},"Amazon S3",[244,961,962],{},"Tujuan: Penyimpanan file dan backup",[244,964,965,968],{},[213,966,967],{},"Analytics",[310,969,970,973],{},[244,971,972],{},"Google Analytics, Microsoft Clarity, PostHog",[244,974,975],{},"Tujuan: Tracking perilaku pengguna dan analytics",[244,977,978,981],{},[213,979,980],{},"KYC Services",[310,982,983,986],{},[244,984,985],{},"Verihubs, Gemini",[244,987,988],{},"Tujuan: Verifikasi identitas",[244,990,991,994],{},[213,992,993],{},"Messaging",[310,995,996,999],{},[244,997,998],{},"WhatsApp API",[244,1000,1001],{},"Tujuan: Notifikasi customer",[244,1003,1004,1007],{},[213,1005,1006],{},"Automation",[310,1008,1009,1012],{},[244,1010,1011],{},"n8n",[244,1013,1014],{},"Tujuan: Otomatisasi workflow",[244,1016,1017,1020],{},[213,1018,1019],{},"Reporting",[310,1021,1022,1025],{},[244,1023,1024],{},"Metabase",[244,1026,1027],{},"Tujuan: Analytics data dan dashboard",[233,1029,1031],{"id":1030},"alur-request","Alur Request",[297,1033,1035],{"id":1034},"alur-request-halaman","Alur Request Halaman",[1037,1038,1043],"pre",{"className":1039,"code":1041,"language":1042},[1040],"language-text","Browser → Router → View (Blade + Vue) → Browser\n","text",[356,1044,1041],{"__ignoreMap":1045},"",[241,1047,1048,1051,1054,1057,1060],{},[244,1049,1050],{},"User mengakses URL halaman",[244,1052,1053],{},"Router menerima request",[244,1055,1056],{},"Router mengarahkan ke View yang sesuai",[244,1058,1059],{},"Blade template render dengan komponen Vue",[244,1061,1062],{},"Response dikirim kembali ke Browser",[297,1064,1066],{"id":1065},"alur-request-api","Alur Request API",[1037,1068,1071],{"className":1069,"code":1070,"language":1042},[1040],"Browser → Router → Controller → Service/Model → Database\n                      ↓\n                   Response ← Service ← Third-party\n",[356,1072,1070],{"__ignoreMap":1045},[241,1074,1075,1078,1081,1084,1087,1090,1093,1096],{},[244,1076,1077],{},"User melakukan aksi (submit form, klik tombol)",[244,1079,1080],{},"Browser mengirim API request",[244,1082,1083],{},"Router mengarahkan ke Controller yang sesuai",[244,1085,1086],{},"Controller memvalidasi request",[244,1088,1089],{},"Controller memanggil Service (jika perlu) atau Model",[244,1091,1092],{},"Service dapat memanggil Third-party services",[244,1094,1095],{},"Model mengeksekusi query database",[244,1097,1098],{},"Response berjalan kembali melalui Controller ke Browser",[297,1100,1102],{"id":1101},"alur-pengiriman-data","Alur Pengiriman Data",[1037,1104,1107],{"className":1105,"code":1106,"language":1042},[1040],"View (Frontend Input) → Controller → Service → Model → Database\n                                       ↓\n                              Third-party Services\n",[356,1108,1106],{"__ignoreMap":1045},[241,1110,1111,1114,1117,1120,1123,1126,1129],{},[244,1112,1113],{},"User mengisi form di View",[244,1115,1116],{},"Komponen Vue mengirim data ke Controller",[244,1118,1119],{},"Controller memvalidasi input",[244,1121,1122],{},"Controller mendelegasikan ke Service (jika kompleks)",[244,1124,1125],{},"Service/Controller menggunakan Model untuk operasi database",[244,1127,1128],{},"Service dapat berinteraksi dengan Third-party services",[244,1130,1131],{},"Response sukses/error dikirim kembali ke View",[233,1133,1135],{"id":1134},"design-pattern","Design Pattern",[297,1137,1139],{"id":1138},"_1-mvc-pattern-model-view-controller","1. MVC Pattern (Model-View-Controller)",[310,1141,1142,1148,1154],{},[244,1143,1144,1147],{},[213,1145,1146],{},"Model",": Data dan business logic",[244,1149,1150,1153],{},[213,1151,1152],{},"View",": Layer presentasi",[244,1155,1156,1159],{},[213,1157,1158],{},"Controller",": Mengorkestrasi Model dan View",[297,1161,1163],{"id":1162},"_2-service-layer-pattern","2. Service Layer Pattern",[310,1165,1166,1169],{},[244,1167,1168],{},"Memisahkan business logic dari controller",[244,1170,1171],{},"Mempromosikan reusability dan testability kode",[297,1173,1175],{"id":1174},"_3-repository-pattern","3. Repository Pattern",[310,1177,1178,1181],{},[244,1179,1180],{},"Model bertindak sebagai repository untuk akses data",[244,1182,1183],{},"Abstraksi atas operasi database",[297,1185,1187],{"id":1186},"_4-dependency-injection","4. Dependency Injection",[310,1189,1190,1193],{},[244,1191,1192],{},"Service container Laravel menangani dependencies",[244,1194,1195],{},"Mempromosikan loose coupling dan testability",[233,1197,183],{"id":1198},"best-practices",[297,1200,1202],{"id":1201},"panduan-controller","Panduan Controller",[241,1204,1205,1208,1211,1213,1216],{},[244,1206,1207],{},"Jaga controller tetap ringan dan fokus",[244,1209,1210],{},"Validasi request menggunakan Form Request class",[244,1212,589],{},[244,1214,1215],{},"Return format response yang konsisten",[244,1217,1218],{},"Gunakan resource controller untuk RESTful API",[297,1220,1222],{"id":1221},"panduan-service","Panduan Service",[241,1224,1225,1228,1231,1234,1237],{},[244,1226,1227],{},"Buat service untuk business logic kompleks",[244,1229,1230],{},"Buat service yang reusable di berbagai controller",[244,1232,1233],{},"Tangani integrasi third-party di service",[244,1235,1236],{},"Tulis unit test untuk method service",[244,1238,1239],{},"Gunakan dependency injection untuk service dependencies",[297,1241,1243],{"id":1242},"panduan-model","Panduan Model",[241,1245,1246,1249,1252,1255,1258],{},[244,1247,1248],{},"Definisikan relasi dengan jelas",[244,1250,1251],{},"Gunakan scope untuk query yang reusable",[244,1253,1254],{},"Implementasikan accessor/mutator untuk transformasi data",[244,1256,1257],{},"Tambahkan aturan validasi di model atau Form Request",[244,1259,1260],{},"Gunakan model event untuk aksi otomatis",[297,1262,1264],{"id":1263},"panduan-view","Panduan View",[241,1266,1267,1270,1273,1276,1279],{},[244,1268,1269],{},"Jaga Blade template tetap bersih dan sederhana",[244,1271,1272],{},"Gunakan komponen Vue untuk elemen interaktif",[244,1274,1275],{},"Pisahkan concern antara Blade dan Vue",[244,1277,1278],{},"Implementasikan data binding yang tepat",[244,1280,1281],{},"Optimalkan rendering komponen",[233,1283,1285],{"id":1284},"pertimbangan-keamanan","Pertimbangan Keamanan",[241,1287,1288,1294,1300,1306,1312,1318,1324,1330],{},[244,1289,1290,1293],{},[213,1291,1292],{},"Input Validation",": Semua input user divalidasi di Form Request",[244,1295,1296,1299],{},[213,1297,1298],{},"CSRF Protection",": Token CSRF Laravel untuk form submission",[244,1301,1302,1305],{},[213,1303,1304],{},"SQL Injection Prevention",": Eloquent ORM mencegah SQL injection",[244,1307,1308,1311],{},[213,1309,1310],{},"XSS Protection",": Blade templating auto-escape output",[244,1313,1314,1317],{},[213,1315,1316],{},"Authentication",": Laravel Sanctum/Passport untuk API authentication",[244,1319,1320,1323],{},[213,1321,1322],{},"Authorization",": Policy dan Gate untuk access control",[244,1325,1326,1329],{},[213,1327,1328],{},"Rate Limiting",": Throttling untuk API endpoint",[244,1331,1332,1335],{},[213,1333,1334],{},"Secure API Keys",": Environment variable untuk data sensitif",[233,1337,1339],{"id":1338},"optimasi-performa","Optimasi Performa",[241,1341,1342,1348,1354,1360,1366,1372,1378],{},[244,1343,1344,1347],{},[213,1345,1346],{},"Query Optimization",": Gunakan eager loading untuk mencegah N+1 query",[244,1349,1350,1353],{},[213,1351,1352],{},"Caching",": Implementasi Redis/Memcached untuk data yang sering diakses",[244,1355,1356,1359],{},[213,1357,1358],{},"Queue Jobs",": Background processing untuk task yang memakan waktu",[244,1361,1362,1365],{},[213,1363,1364],{},"Database Indexing",": Index yang tepat pada kolom yang sering di-query",[244,1367,1368,1371],{},[213,1369,1370],{},"Asset Optimization",": Minifikasi dan bundling JS/CSS",[244,1373,1374,1377],{},[213,1375,1376],{},"CDN Usage",": Serve static asset via CDN",[244,1379,1380,1383],{},[213,1381,1382],{},"Database Connection Pooling",": Reuse koneksi database",[233,1385,1387],{"id":1386},"kesimpulan","Kesimpulan",[209,1389,1390],{},"Arsitektur TriPay menggabungkan ketangguhan pola MVC Laravel dengan kapabilitas frontend Vue.js modern, menciptakan aplikasi monolithic yang maintainable dan scalable. Penambahan Service layer memberikan separation of concerns yang lebih baik, membuat codebase lebih terorganisir, testable, dan lebih mudah di-maintain seiring pertumbuhan aplikasi.",{"title":1045,"searchDepth":1392,"depth":1392,"links":1393},2,[1394,1395,1406,1411,1417,1423,1424,1425],{"id":235,"depth":1392,"text":236},{"id":294,"depth":1392,"text":295,"children":1396},[1397,1399,1400,1401,1402,1403,1404,1405],{"id":299,"depth":1398,"text":300},3,{"id":326,"depth":1398,"text":327},{"id":411,"depth":1398,"text":412},{"id":504,"depth":1398,"text":505},{"id":607,"depth":1398,"text":608},{"id":726,"depth":1398,"text":727},{"id":834,"depth":1398,"text":835},{"id":909,"depth":1398,"text":910},{"id":1030,"depth":1392,"text":1031,"children":1407},[1408,1409,1410],{"id":1034,"depth":1398,"text":1035},{"id":1065,"depth":1398,"text":1066},{"id":1101,"depth":1398,"text":1102},{"id":1134,"depth":1392,"text":1135,"children":1412},[1413,1414,1415,1416],{"id":1138,"depth":1398,"text":1139},{"id":1162,"depth":1398,"text":1163},{"id":1174,"depth":1398,"text":1175},{"id":1186,"depth":1398,"text":1187},{"id":1198,"depth":1392,"text":183,"children":1418},[1419,1420,1421,1422],{"id":1201,"depth":1398,"text":1202},{"id":1221,"depth":1398,"text":1222},{"id":1242,"depth":1398,"text":1243},{"id":1263,"depth":1398,"text":1264},{"id":1284,"depth":1392,"text":1285},{"id":1338,"depth":1392,"text":1339},{"id":1386,"depth":1392,"text":1387},"Arsitektur Laravel MVC dengan integrasi frontend Vue.js","md",null,{},{"icon":17},{"title":167,"description":1426},"1t3Jcx_fWHrp_wsZ1j7TolpPojHb3gD3d--6BLxRGJ8",[1434,1435],{"title":163,"path":164,"stem":165,"description":1428,"icon":17,"children":-1},{"title":171,"path":172,"stem":173,"description":1436,"children":-1},"This section explains the frontend architecture and structure.",1766369384554]