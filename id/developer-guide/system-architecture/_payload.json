notification/1.whatsapp-notification",{"title":113,"icon":17,"path":114,"stem":115,"children":116,"page":17},"Integrasi","/id/introduction/integrations","id/1.introduction/7.integrations",[117,121,125,129],{"title":118,"path":119,"stem":120,"icon":17},"Callback tester","/id/introduction/integrations/callback-tester","id/1.introduction/7.integrations/1.callback-tester",{"title":122,"path":123,"stem":124,"icon":17},"Sandbox","/id/introduction/integrations/sandbox","id/1.introduction/7.integrations/2.sandbox",{"title":126,"path":127,"stem":128,"icon":17},"Production","/id/introduction/integrations/production","id/1.introduction/7.integrations/3.production",{"title":130,"path":131,"stem":132,"icon":17},"Plugin","/id/introduction/integrations/plugin","id/1.introduction/7.integrations/4.plugin",{"title":134,"icon":17,"path":135,"stem":136,"children":137,"page":17},"Referral","/id/introduction/referral","id/1.introduction/8.referral",[138],{"title":134,"path":139,"stem":140,"icon":17},"/id/introduction/referral/referral","id/1.introduction/8.referral/1.referral",{"title":142,"icon":17,"path":143,"stem":144,"children":145,"page":17},"FAQs","/id/introduction/faqs","id/1.introduction/9.faqs",[146],{"title":142,"path":147,"stem":148,"icon":17},"/id/introduction/faqs/faqs","id/1.introduction/9.faqs/1.faqs",{"title":150,"path":151,"stem":152,"children":153,"page":17},"Developer Guide","/id/developer-guide","id/2.developer-guide",[154,158,162,166,170,174,178,182,186],{"title":155,"path":156,"stem":157},"Installation and Requirements","/id/developer-guide/installation-and-requirements","id/2.developer-guide/1.installation-and-requirements",{"title":159,"path":160,"stem":161},"Development Workflow","/id/developer-guide/development-workflow","id/2.developer-guide/2.development-workflow",{"title":163,"path":164,"stem":165,"icon":17},"Arsitektur Sistem","/id/developer-guide/system-architecture","id/2.developer-guide/3.system-architecture",{"title":167,"path":168,"stem":169,"icon":17},"Arsitektur Backend","/id/developer-guide/backend-architecture","id/2.developer-guide/4.backend-architecture",{"title":171,"path":172,"stem":173},"Frontend Architecture","/id/developer-guide/frontend-architecture","id/2.developer-guide/5.frontend-architecture",{"title":175,"path":176,"stem":177},"Database","/id/developer-guide/database","id/2.developer-guide/6.database",{"title":179,"path":180,"stem":181},"Coding Standard","/id/developer-guide/coding-standard","id/2.developer-guide/7.coding-standard",{"title":183,"path":184,"stem":185},"Best Practices","/id/developer-guide/best-practices","id/2.developer-guide/8.best-practices",{"title":187,"path":188,"stem":189},"Testing","/id/developer-guide/testing","id/2.developer-guide/9.testing",{"title":191,"path":192,"stem":193,"children":194,"page":17},"Api References","/id/api-references","id/3.api-references",[195,199],{"title":196,"path":197,"stem":198},"API Endpoints","/id/api-references/api-endpoints","id/3.api-references/1.api-endpoints",{"title":200,"path":201,"stem":202},"Usage Guide","/id/api-references/usage-guide","id/3.api-references/2.usage-guide",{"id":204,"title":163,"body":205,"description":637,"extension":638,"links":637,"meta":639,"navigation":640,"path":164,"seo":641,"stem":165,"__hash__":642},"docs_id/id/2.developer-guide/3.system-architecture.md",{"type":206,"value":207,"toc":626},"minimark",[208,212,218,223,315,319,324,329,333,338,355,360,413,418,440,445,473,478,516,521,565,570,584,588,593,607,612],[209,210,211],"p",{},"Sistem TriPay didesain untuk memproses transaksi pembayaran dengan aman dan stabil bagi end-users melalui API dan berinteraksi dengan web app Laravel + Vue melalui setup server yang terpisah, sesuai dengan penggunaannya.",[209,213,214],{},[215,216],"img",{"alt":163,"src":217},"/images/system-architecture.png",[219,220,222],"h2",{"id":221},"rincian-komponen","Rincian Komponen",[224,225,226,234,240,246,272,278,284],"ol",{},[227,228,229,233],"li",{},[230,231,232],"strong",{},"End-User",": Pengguna akhir berinteraksi dengan website Tripay untuk melakukan pendaftaran, konfigurasi merchant, dan melihat detail transaksi.",[227,235,236,239],{},[230,237,238],{},"Merchant Server",": Server merchant yang melakukan integrasi API Tripay untuk memproses transaksi.",[227,241,242,245],{},[230,243,244],{},"Lapisan Cloudflare",": Semua traffic masuk dan keluar dialihkan melalui Cloudflare untuk menyediakan perlindungan DDoS, aturan pemfilteran IP, dan caching resource.",[227,247,248,251,252],{},[230,249,250],{},"Server Kolokasi Maxcloud",":",[253,254,255,261,267],"ul",{},[227,256,257,260],{},[230,258,259],{},"Webhook Service",": Mengirim notifikasi asinkron (callback) dari Tripay ke server merchant terkait pembaruan status transaksi.",[227,262,263,266],{},[230,264,265],{},"Web App",": Aplikasi monolith Laravel yang menangani layanan frontend (Vue.js) dan backend, termasuk user interface, pemrosesan logika bisnis, dan API endpoint untuk integrasi merchant.",[227,268,269,271],{},[230,270,175],{},": Sistem database relasional untuk menyimpan data pengguna, catatan transaksi, pengaturan, dan log.",[227,273,274,277],{},[230,275,276],{},"Penyedia Layanan Pembayaran",": Sistem terhubung ke beberapa penyedia layanan pembayaran dan agregator (misalnya, Bank BCA, BNI, Neo, NOBU, Prismalink, DurianPay, LinkQu, Esmartlink, PakaiLink) untuk memproses berbagai macam pembayaran bank/QRIS.",[227,279,280,283],{},[230,281,282],{},"Bank",": Tujuan akhir dari dana settlement; perpindahan uang yang sebenarnya terjadi di sini melalui integrasi penyedia layanan pembayaran.",[227,285,286,251,289],{},[230,287,288],{},"Integrasi & Tools Pihak Ketiga",[253,290,291,297,303,309],{},[227,292,293,296],{},[230,294,295],{},"Email dan Storage",": Amazon SES untuk pengiriman email transaksional dan S3 untuk menyimpan file dan data pengguna.",[227,298,299,302],{},[230,300,301],{},"Analytics",": Google Analytics, Microsoft Clarity, dan PostHog untuk pelacakan aktivitas pengguna, analitik produk, dan heatmap.",[227,304,305,308],{},[230,306,307],{},"Layanan Pihak Ketiga",": Verihubs dan Gemini untuk verifikasi identitas/KYC, WhatsApp API untuk notifikasi pelanggan.",[227,310,311,314],{},[230,312,313],{},"Tools Lainnya",": n8n untuk otomatisasi workflow, Metabase untuk analitik data/dashboard, OpnForm untuk manajemen form dan use case internal.",[219,316,318],{"id":317},"alur-data-dan-proses","Alur Data dan Proses",[320,321,323],"h3",{"id":322},"diagram-aktivitas-transaksi","Diagram Aktivitas Transaksi",[325,326],"mermaid",{":config":327,"code":328},"config","sequenceDiagram%0A%20%20%20%20participant%20Customer%0A%20%20%20%20participant%20Merchant%0A%20%20%20%20participant%20Tripay%0A%20%20%20%20participant%20Provider%20as%20Payment%20Provider%0A%20%20%20%20participant%20Bank%0A%0A%20%20%20%20Note%20over%20Customer%2CBank%3A%20Alur%20Transaksi%20dengan%205%20Aktor%0A%0A%20%20%20%20%25%25%20Fase%201%3A%20Customer%20Memulai%20Pembelian%0A%20%20%20%20Customer-%3E%3EMerchant%3A%20Browse%20produk%20%26%20tambah%20ke%20keranjang%0A%20%20%20%20Customer-%3E%3EMerchant%3A%20Lanjut%20ke%20checkout%0A%20%20%20%20Customer-%3E%3EMerchant%3A%20Isi%20detail%20pesanan%20%26%20pilih%20metode%20pembayaran%0A%20%20%20%20Customer-%3E%3EMerchant%3A%20Konfirmasi%20pesanan%0A%0A%20%20%20%20%25%25%20Fase%202%3A%20Inisiasi%20Transaksi%0A%20%20%20%20Merchant-%3E%3EMerchant%3A%20Persiapkan%20data%20transaksi%0A%20%20%20%20Merchant-%3E%3ETripay%3A%20POST%20%2Ftransaction%2Fcreate%3Cbr%2F%3E(Order%20ID%2C%20Jumlah%2C%20Metode%20Pembayaran)%0A%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Validasi%20kredensial%20API%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Validasi%20parameter%20request%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Cek%20status%20merchant%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Buat%20record%20transaksi%20di%20DB%0A%20%20%20%20Tripay-%3E%3EProvider%3A%20Request%20payment%20channel%3Cbr%2F%3E(Nomor%20VA%2FQR%20Code)%0A%20%20%20%20Provider-%3E%3ETripay%3A%20Return%20detail%20pembayaran%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Generate%20referensi%20pembayaran%0A%20%20%20%20Tripay-%3E%3EMerchant%3A%20Return%20API%20response%3Cbr%2F%3E(Referensi%2C%20VA%2FQR%2C%20Instruksi)%0A%0A%20%20%20%20%25%25%20Fase%203%3A%20Tampilkan%20Pembayaran%0A%20%20%20%20Merchant-%3E%3EMerchant%3A%20Proses%20response%20Tripay%0A%20%20%20%20Merchant-%3E%3ECustomer%3A%20Tampilkan%20instruksi%20pembayaran%3Cbr%2F%3E(QR%20Code%2FNomor%20VA%2C%20Jumlah%2C%20Expiry)%0A%0A%20%20%20%20%25%25%20Fase%204%3A%20Proses%20Pembayaran%0A%20%20%20%20Customer-%3E%3EBank%3A%20Scan%20QR%20Code%20%2F%20Transfer%20ke%20VA%0A%20%20%20%20Bank-%3E%3EBank%3A%20Proses%20transaksi%0A%20%20%20%20Bank-%3E%3EBank%3A%20Kurangi%20saldo%20customer%0A%20%20%20%20Bank-%3E%3EProvider%3A%20Kirim%20notifikasi%20pembayaran%0A%20%20%20%20Provider-%3E%3EProvider%3A%20Verifikasi%20transaksi%0A%20%20%20%20Provider-%3E%3EBank%3A%20Request%20settlement%20dana%0A%20%20%20%20Bank-%3E%3EProvider%3A%20Transfer%20dana%0A%0A%20%20%20%20%25%25%20Fase%205%3A%20Konfirmasi%20Pembayaran%20ke%20Tripay%0A%20%20%20%20Provider-%3E%3ETripay%3A%20Kirim%20webhook%2Fcallback%3Cbr%2F%3E(Referensi%2C%20Status%2C%20Jumlah%2C%20Timestamp)%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Validasi%20signature%20callback%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Verifikasi%20referensi%20transaksi%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Update%20status%20transaksi%20ke%20PAID%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Catat%20detail%20pembayaran%0A%0A%20%20%20%20%25%25%20Fase%206%3A%20Notifikasi%20Merchant%0A%20%20%20%20Tripay-%3E%3EMerchant%3A%20Kirim%20webhook%20callback%3Cbr%2F%3E(Order%20ID%2C%20Status%2C%20Detail%20Pembayaran)%0A%20%20%20%20Merchant-%3E%3EMerchant%3A%20Validasi%20signature%20callback%0A%20%20%20%20Merchant-%3E%3EMerchant%3A%20Update%20status%20pesanan%0A%20%20%20%20Merchant-%3E%3EMerchant%3A%20Proses%20pemenuhan%20pesanan%0A%0A%20%20%20%20%25%25%20Fase%207%3A%20Konfirmasi%20Customer%0A%20%20%20%20Merchant-%3E%3ECustomer%3A%20Kirim%20notifikasi%20pembayaran%20sukses%3Cbr%2F%3E(Email%2FSMS%2FWhatsApp)%0A%20%20%20%20Merchant-%3E%3ECustomer%3A%20Kirim%20konfirmasi%20pesanan%20%26%20invoice%0A%20%20%20%20Customer-%3E%3ECustomer%3A%20Terima%20konfirmasi%0A%20%20%20%20Customer-%3E%3EMerchant%3A%20Lacak%20status%20pesanan%0A%0A%20%20%20%20Note%20over%20Customer%2CBank%3A%20Transaksi%20Selesai%20%E2%9C%93",[320,330,332],{"id":331},"alur-transaksi-lengkap","Alur Transaksi Lengkap",[209,334,335],{},[230,336,337],{},"1. Customer Memulai Pembelian (Customer → Merchant)",[224,339,340,343,346,349,352],{},[227,341,342],{},"Customer menjelajahi produk/layanan di website merchant",[227,344,345],{},"Customer menambahkan item ke keranjang dan melanjutkan ke checkout",[227,347,348],{},"Customer mengisi detail pesanan (info pengiriman, kontak, dll.)",[227,350,351],{},"Customer memilih metode pembayaran dan mengkonfirmasi pesanan",[227,353,354],{},"Server merchant menerima data pesanan dan mempersiapkan transaksi",[209,356,357],{},[230,358,359],{},"2. Inisiasi Transaksi (Merchant → Tripay)",[224,361,362,370,373,387,390,393],{},[227,363,364,365],{},"Server merchant mengirim request API ke Tripay dengan detail transaksi:\n",[253,366,367],{},[227,368,369],{},"Order ID, jumlah, info customer, metode pembayaran yang dipilih",[227,371,372],{},"Request melewati layer Cloudflare",[227,374,375,376],{},"Tripay Web App menerima dan memvalidasi request:\n",[253,377,378,381,384],{},[227,379,380],{},"Validasi kredensial API (Merchant Code, API Key, Signature)",[227,382,383],{},"Validasi parameter request",[227,385,386],{},"Cek status merchant dan saldo",[227,388,389],{},"Tripay membuat record transaksi di Database",[227,391,392],{},"Tripay generate instruksi pembayaran/nomor referensi",[227,394,395,396],{},"Tripay mengembalikan response API ke merchant dengan:\n",[253,397,398,401,404,407,410],{},[227,399,400],{},"Referensi transaksi",[227,402,403],{},"Instruksi pembayaran",[227,405,406],{},"QR code (untuk QRIS)",[227,408,409],{},"Nomor virtual account (untuk transfer bank)",[227,411,412],{},"Payment URL/redirect link",[209,414,415],{},[230,416,417],{},"3. Tampilan Pembayaran (Merchant → Customer)",[224,419,420,423,437],{},[227,421,422],{},"Server merchant menerima response dari Tripay",[227,424,425,426],{},"Merchant menampilkan instruksi pembayaran ke customer:\n",[253,427,428,431,434],{},[227,429,430],{},"Menampilkan detail metode pembayaran",[227,432,433],{},"Menampilkan QR code atau nomor VA",[227,435,436],{},"Menampilkan jumlah pembayaran dan waktu kadaluarsa",[227,438,439],{},"Customer melihat instruksi pembayaran",[209,441,442],{},[230,443,444],{},"4. Proses Pembayaran (Customer → Payment Provider → Bank)",[224,446,447,461,464,467,470],{},[227,448,449,450],{},"Customer menyelesaikan pembayaran:\n",[253,451,452,455,458],{},[227,453,454],{},"Scan QR code dengan aplikasi banking, ATAU",[227,456,457],{},"Transfer ke nomor virtual account, ATAU",[227,459,460],{},"Menggunakan e-wallet/metode pembayaran lainnya",[227,462,463],{},"Bank customer memproses transaksi",[227,465,466],{},"Payment Provider menerima notifikasi pembayaran dari bank",[227,468,469],{},"Payment Provider memverifikasi dan memproses transaksi",[227,471,472],{},"Dana ditransfer ke rekening bank yang dituju",[209,474,475],{},[230,476,477],{},"5. Notifikasi Pembayaran (Bank → Payment Provider → Tripay)",[224,479,480,483,499,510,513],{},[227,481,482],{},"Bank mengirim konfirmasi pembayaran ke Payment Provider",[227,484,485,486],{},"Payment Provider mengirim webhook/callback ke Tripay:\n",[253,487,488,490,493,496],{},[227,489,400],{},[227,491,492],{},"Status pembayaran (success/failed)",[227,494,495],{},"Jumlah pembayaran",[227,497,498],{},"Timestamp pembayaran",[227,500,501,502],{},"Tripay menerima dan memvalidasi callback:\n",[253,503,504,507],{},[227,505,506],{},"Validasi sumber/signature callback",[227,508,509],{},"Cek referensi transaksi",[227,511,512],{},"Tripay update status transaksi di Database",[227,514,515],{},"Tripay mencatat detail pembayaran dan timestamp",[209,517,518],{},[230,519,520],{},"6. Notifikasi Merchant (Tripay → Merchant)",[224,522,523,539,542,545,548,551],{},[227,524,525,526],{},"Tripay Webhook Service mengirim callback ke callback URL merchant:\n",[253,527,528,530,533,536],{},[227,529,400],{},[227,531,532],{},"Order ID",[227,534,535],{},"Status pembayaran",[227,537,538],{},"Detail pembayaran",[227,540,541],{},"Server merchant menerima notifikasi callback",[227,543,544],{},"Merchant memvalidasi signature callback",[227,546,547],{},"Merchant update status pesanan di sistem mereka",[227,549,550],{},"Merchant mengirim konfirmasi pesanan ke customer (email/SMS/WhatsApp)",[227,552,553,554],{},"Merchant memproses pemenuhan pesanan:\n",[253,555,556,559,562],{},[227,557,558],{},"Generate invoice",[227,560,561],{},"Persiapan pengiriman",[227,563,564],{},"Aktivasi produk/layanan digital",[209,566,567],{},[230,568,569],{},"7. Konfirmasi Customer (Merchant → Customer)",[224,571,572,575,578,581],{},[227,573,574],{},"Customer menerima notifikasi pembayaran sukses",[227,576,577],{},"Customer menerima konfirmasi pesanan",[227,579,580],{},"Customer dapat melacak status pesanan",[227,582,583],{},"Transaksi selesai",[320,585,587],{"id":586},"proses-tambahan","Proses Tambahan",[209,589,590,251],{},[230,591,592],{},"Pelaporan & Analitik",[253,594,595,598,601,604],{},[227,596,597],{},"Semua aktivitas transaksi dicatat ke Database",[227,599,600],{},"Log aktivitas dikirim ke tools Analytics (Google Analytics, Clarity, PostHog)",[227,602,603],{},"Data transaksi tersedia di Metabase untuk reporting",[227,605,606],{},"Merchant dapat melihat laporan transaksi di dashboard Tripay",[209,608,609,251],{},[230,610,611],{},"Penanganan Transaksi Gagal",[253,613,614,617,620,623],{},[227,615,616],{},"Jika pembayaran gagal atau kadaluarsa, status diupdate sesuai",[227,618,619],{},"Notifikasi webhook dikirim ke merchant dengan status gagal",[227,621,622],{},"Customer diberitahu tentang kegagalan pembayaran",[227,624,62