otification/1.whatsapp-notification",{"title":112,"icon":17,"path":113,"stem":114,"children":115,"page":17},"Integrasi","/id/introduction/integrations","id/1.introduction/7.integrations",[116,120,124,128],{"title":117,"path":118,"stem":119,"icon":17},"Callback tester","/id/introduction/integrations/callback-tester","id/1.introduction/7.integrations/1.callback-tester",{"title":121,"path":122,"stem":123,"icon":17},"Sandbox","/id/introduction/integrations/sandbox","id/1.introduction/7.integrations/2.sandbox",{"title":125,"path":126,"stem":127,"icon":17},"Production","/id/introduction/integrations/production","id/1.introduction/7.integrations/3.production",{"title":129,"path":130,"stem":131,"icon":17},"Plugin","/id/introduction/integrations/plugin","id/1.introduction/7.integrations/4.plugin",{"title":133,"icon":17,"path":134,"stem":135,"children":136,"page":17},"Referral","/id/introduction/referral","id/1.introduction/8.referral",[137],{"title":133,"path":138,"stem":139,"icon":17},"/id/introduction/referral/referral","id/1.introduction/8.referral/1.referral",{"title":141,"icon":17,"path":142,"stem":143,"children":144,"page":17},"FAQs","/id/introduction/faqs","id/1.introduction/9.faqs",[145],{"title":141,"path":146,"stem":147,"icon":17},"/id/introduction/faqs/faqs","id/1.introduction/9.faqs/1.faqs",{"title":149,"path":150,"stem":151,"children":152,"page":17},"Developer Guide","/id/developer-guide","id/2.developer-guide",[153,157,161,165,169,173,177,181,185],{"title":154,"path":155,"stem":156},"Installation and Requirements","/id/developer-guide/installation-and-requirements","id/2.developer-guide/1.installation-and-requirements",{"title":158,"path":159,"stem":160},"Development Workflow","/id/developer-guide/development-workflow","id/2.developer-guide/2.development-workflow",{"title":162,"path":163,"stem":164,"icon":17},"Arsitektur Sistem","/id/developer-guide/system-architecture","id/2.developer-guide/3.system-architecture",{"title":166,"path":167,"stem":168,"icon":17},"Arsitektur Backend","/id/developer-guide/backend-architecture","id/2.developer-guide/4.backend-architecture",{"title":170,"path":171,"stem":172},"Frontend Architecture","/id/developer-guide/frontend-architecture","id/2.developer-guide/5.frontend-architecture",{"title":174,"path":175,"stem":176},"Database","/id/developer-guide/database","id/2.developer-guide/6.database",{"title":178,"path":179,"stem":180},"Coding Standard","/id/developer-guide/coding-standard","id/2.developer-guide/7.coding-standard",{"title":182,"path":183,"stem":184},"Best Practices","/id/developer-guide/best-practices","id/2.developer-guide/8.best-practices",{"title":186,"path":187,"stem":188},"Testing","/id/developer-guide/testing","id/2.developer-guide/9.testing",{"title":190,"path":191,"stem":192,"children":193,"page":17},"Api References","/id/api-references","id/3.api-references",[194,198],{"title":195,"path":196,"stem":197},"API Endpoints","/id/api-references/api-endpoints","id/3.api-references/1.api-endpoints",{"title":199,"path":200,"stem":201},"Usage Guide","/id/api-references/usage-guide","id/3.api-references/2.usage-guide",{"id":203,"title":162,"body":204,"description":636,"extension":637,"links":636,"meta":638,"navigation":639,"path":163,"seo":640,"stem":164,"__hash__":641},"docs_id/id/2.developer-guide/3.system-architecture.md",{"type":205,"value":206,"toc":625},"minimark",[207,211,217,222,314,318,323,328,332,337,354,359,412,417,439,444,472,477,515,520,564,569,583,587,592,606,611],[208,209,210],"p",{},"Sistem TriPay didesain untuk memproses transaksi pembayaran dengan aman dan stabil bagi end-users melalui API dan berinteraksi dengan web app Laravel + Vue melalui setup server yang terpisah, sesuai dengan penggunaannya.",[208,212,213],{},[214,215],"img",{"alt":162,"src":216},"/images/system-architecture.png",[218,219,221],"h2",{"id":220},"rincian-komponen","Rincian Komponen",[223,224,225,233,239,245,271,277,283],"ol",{},[226,227,228,232],"li",{},[229,230,231],"strong",{},"End-User",": Pengguna akhir berinteraksi dengan website Tripay untuk melakukan pendaftaran, konfigurasi merchant, dan melihat detail transaksi.",[226,234,235,238],{},[229,236,237],{},"Merchant Server",": Server merchant yang melakukan integrasi API Tripay untuk memproses transaksi.",[226,240,241,244],{},[229,242,243],{},"Lapisan Cloudflare",": Semua traffic masuk dan keluar dialihkan melalui Cloudflare untuk menyediakan perlindungan DDoS, aturan pemfilteran IP, dan caching resource.",[226,246,247,250,251],{},[229,248,249],{},"Server Kolokasi Maxcloud",":",[252,253,254,260,266],"ul",{},[226,255,256,259],{},[229,257,258],{},"Webhook Service",": Mengirim notifikasi asinkron (callback) dari Tripay ke server merchant terkait pembaruan status transaksi.",[226,261,262,265],{},[229,263,264],{},"Web App",": Aplikasi monolith Laravel yang menangani layanan frontend (Vue.js) dan backend, termasuk user interface, pemrosesan logika bisnis, dan API endpoint untuk integrasi merchant.",[226,267,268,270],{},[229,269,174],{},": Sistem database relasional untuk menyimpan data pengguna, catatan transaksi, pengaturan, dan log.",[226,272,273,276],{},[229,274,275],{},"Penyedia Layanan Pembayaran",": Sistem terhubung ke beberapa penyedia layanan pembayaran dan agregator (misalnya, Bank BCA, BNI, Neo, NOBU, Prismalink, DurianPay, LinkQu, Esmartlink, PakaiLink) untuk memproses berbagai macam pembayaran bank/QRIS.",[226,278,279,282],{},[229,280,281],{},"Bank",": Tujuan akhir dari dana settlement; perpindahan uang yang sebenarnya terjadi di sini melalui integrasi penyedia layanan pembayaran.",[226,284,285,250,288],{},[229,286,287],{},"Integrasi & Tools Pihak Ketiga",[252,289,290,296,302,308],{},[226,291,292,295],{},[229,293,294],{},"Email dan Storage",": Amazon SES untuk pengiriman email transaksional dan S3 untuk menyimpan file dan data pengguna.",[226,297,298,301],{},[229,299,300],{},"Analytics",": Google Analytics, Microsoft Clarity, dan PostHog untuk pelacakan aktivitas pengguna, analitik produk, dan heatmap.",[226,303,304,307],{},[229,305,306],{},"Layanan Pihak Ketiga",": Verihubs dan Gemini untuk verifikasi identitas/KYC, WhatsApp API untuk notifikasi pelanggan.",[226,309,310,313],{},[229,311,312],{},"Tools Lainnya",": n8n untuk otomatisasi workflow, Metabase untuk analitik data/dashboard, OpnForm untuk manajemen form dan use case internal.",[218,315,317],{"id":316},"alur-data-dan-proses","Alur Data dan Proses",[319,320,322],"h3",{"id":321},"diagram-aktivitas-transaksi","Diagram Aktivitas Transaksi",[324,325],"mermaid",{":config":326,"code":327},"config","sequenceDiagram%0A%20%20%20%20participant%20Customer%0A%20%20%20%20participant%20Merchant%0A%20%20%20%20participant%20Tripay%0A%20%20%20%20participant%20Provider%20as%20Payment%20Provider%0A%20%20%20%20participant%20Bank%0A%0A%20%20%20%20Note%20over%20Customer%2CBank%3A%20Alur%20Transaksi%20dengan%205%20Aktor%0A%0A%20%20%20%20%25%25%20Fase%201%3A%20Customer%20Memulai%20Pembelian%0A%20%20%20%20Customer-%3E%3EMerchant%3A%20Browse%20produk%20%26%20tambah%20ke%20keranjang%0A%20%20%20%20Customer-%3E%3EMerchant%3A%20Lanjut%20ke%20checkout%0A%20%20%20%20Customer-%3E%3EMerchant%3A%20Isi%20detail%20pesanan%20%26%20pilih%20metode%20pembayaran%0A%20%20%20%20Customer-%3E%3EMerchant%3A%20Konfirmasi%20pesanan%0A%0A%20%20%20%20%25%25%20Fase%202%3A%20Inisiasi%20Transaksi%0A%20%20%20%20Merchant-%3E%3EMerchant%3A%20Persiapkan%20data%20transaksi%0A%20%20%20%20Merchant-%3E%3ETripay%3A%20POST%20%2Ftransaction%2Fcreate%3Cbr%2F%3E(Order%20ID%2C%20Jumlah%2C%20Metode%20Pembayaran)%0A%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Validasi%20kredensial%20API%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Validasi%20parameter%20request%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Cek%20status%20merchant%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Buat%20record%20transaksi%20di%20DB%0A%20%20%20%20Tripay-%3E%3EProvider%3A%20Request%20payment%20channel%3Cbr%2F%3E(Nomor%20VA%2FQR%20Code)%0A%20%20%20%20Provider-%3E%3ETripay%3A%20Return%20detail%20pembayaran%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Generate%20referensi%20pembayaran%0A%20%20%20%20Tripay-%3E%3EMerchant%3A%20Return%20API%20response%3Cbr%2F%3E(Referensi%2C%20VA%2FQR%2C%20Instruksi)%0A%0A%20%20%20%20%25%25%20Fase%203%3A%20Tampilkan%20Pembayaran%0A%20%20%20%20Merchant-%3E%3EMerchant%3A%20Proses%20response%20Tripay%0A%20%20%20%20Merchant-%3E%3ECustomer%3A%20Tampilkan%20instruksi%20pembayaran%3Cbr%2F%3E(QR%20Code%2FNomor%20VA%2C%20Jumlah%2C%20Expiry)%0A%0A%20%20%20%20%25%25%20Fase%204%3A%20Proses%20Pembayaran%0A%20%20%20%20Customer-%3E%3EBank%3A%20Scan%20QR%20Code%20%2F%20Transfer%20ke%20VA%0A%20%20%20%20Bank-%3E%3EBank%3A%20Proses%20transaksi%0A%20%20%20%20Bank-%3E%3EBank%3A%20Kurangi%20saldo%20customer%0A%20%20%20%20Bank-%3E%3EProvider%3A%20Kirim%20notifikasi%20pembayaran%0A%20%20%20%20Provider-%3E%3EProvider%3A%20Verifikasi%20transaksi%0A%20%20%20%20Provider-%3E%3EBank%3A%20Request%20settlement%20dana%0A%20%20%20%20Bank-%3E%3EProvider%3A%20Transfer%20dana%0A%0A%20%20%20%20%25%25%20Fase%205%3A%20Konfirmasi%20Pembayaran%20ke%20Tripay%0A%20%20%20%20Provider-%3E%3ETripay%3A%20Kirim%20webhook%2Fcallback%3Cbr%2F%3E(Referensi%2C%20Status%2C%20Jumlah%2C%20Timestamp)%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Validasi%20signature%20callback%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Verifikasi%20referensi%20transaksi%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Update%20status%20transaksi%20ke%20PAID%0A%20%20%20%20Tripay-%3E%3ETripay%3A%20Catat%20detail%20pembayaran%0A%0A%20%20%20%20%25%25%20Fase%206%3A%20Notifikasi%20Merchant%0A%20%20%20%20Tripay-%3E%3EMerchant%3A%20Kirim%20webhook%20callback%3Cbr%2F%3E(Order%20ID%2C%20Status%2C%20Detail%20Pembayaran)%0A%20%20%20%20Merchant-%3E%3EMerchant%3A%20Validasi%20signature%20callback%0A%20%20%20%20Merchant-%3E%3EMerchant%3A%20Update%20status%20pesanan%0A%20%20%20%20Merchant-%3E%3EMerchant%3A%20Proses%20pemenuhan%20pesanan%0A%0A%20%20%20%20%25%25%20Fase%207%3A%20Konfirmasi%20Customer%0A%20%20%20%20Merchant-%3E%3ECustomer%3A%20Kirim%20notifikasi%20pembayaran%20sukses%3Cbr%2F%3E(Email%2FSMS%2FWhatsApp)%0A%20%20%20%20Merchant-%3E%3ECustomer%3A%20Kirim%20konfirmasi%20pesanan%20%26%20invoice%0A%20%20%20%20Customer-%3E%3ECustomer%3A%20Terima%20konfirmasi%0A%20%20%20%20Customer-%3E%3EMerchant%3A%20Lacak%20status%20pesanan%0A%0A%20%20%20%20Note%20over%20Customer%2CBank%3A%20Transaksi%20Selesai%20%E2%9C%93",[319,329,331],{"id":330},"alur-transaksi-lengkap","Alur Transaksi Lengkap",[208,333,334],{},[229,335,336],{},"1. Customer Memulai Pembelian (Customer → Merchant)",[223,338,339,342,345,348,351],{},[226,340,341],{},"Customer menjelajahi produk/layanan di website merchant",[226,343,344],{},"Customer menambahkan item ke keranjang dan melanjutkan ke checkout",[226,346,347],{},"Customer mengisi detail pesanan (info pengiriman, kontak, dll.)",[226,349,350],{},"Customer memilih metode pembayaran dan mengkonfirmasi pesanan",[226,352,353],{},"Server merchant menerima data pesanan dan mempersiapkan transaksi",[208,355,356],{},[229,357,358],{},"2. Inisiasi Transaksi (Merchant → Tripay)",[223,360,361,369,372,386,389,392],{},[226,362,363,364],{},"Server merchant mengirim request API ke Tripay dengan detail transaksi:\n",[252,365,366],{},[226,367,368],{},"Order ID, jumlah, info customer, metode pembayaran yang dipilih",[226,370,371],{},"Request melewati layer Cloudflare",[226,373,374,375],{},"Tripay Web App menerima dan memvalidasi request:\n",[252,376,377,380,383],{},[226,378,379],{},"Validasi kredensial API (Merchant Code, API Key, Signature)",[226,381,382],{},"Validasi parameter request",[226,384,385],{},"Cek status merchant dan saldo",[226,387,388],{},"Tripay membuat record transaksi di Database",[226,390,391],{},"Tripay generate instruksi pembayaran/nomor referensi",[226,393,394,395],{},"Tripay mengembalikan response API ke merchant dengan:\n",[252,396,397,400,403,406,409],{},[226,398,399],{},"Referensi transaksi",[226,401,402],{},"Instruksi pembayaran",[226,404,405],{},"QR code (untuk QRIS)",[226,407,408],{},"Nomor virtual account (untuk transfer bank)",[226,410,411],{},"Payment URL/redirect link",[208,413,414],{},[229,415,416],{},"3. Tampilan Pembayaran (Merchant → Customer)",[223,418,419,422,436],{},[226,420,421],{},"Server merchant menerima response dari Tripay",[226,423,424,425],{},"Merchant menampilkan instruksi pembayaran ke customer:\n",[252,426,427,430,433],{},[226,428,429],{},"Menampilkan detail metode pembayaran",[226,431,432],{},"Menampilkan QR code atau nomor VA",[226,434,435],{},"Menampilkan jumlah pembayaran dan waktu kadaluarsa",[226,437,438],{},"Customer melihat instruksi pembayaran",[208,440,441],{},[229,442,443],{},"4. Proses Pembayaran (Customer → Payment Provider → Bank)",[223,445,446,460,463,466,469],{},[226,447,448,449],{},"Customer menyelesaikan pembayaran:\n",[252,450,451,454,457],{},[226,452,453],{},"Scan QR code dengan aplikasi banking, ATAU",[226,455,456],{},"Transfer ke nomor virtual account, ATAU",[226,458,459],{},"Menggunakan e-wallet/metode pembayaran lainnya",[226,461,462],{},"Bank customer memproses transaksi",[226,464,465],{},"Payment Provider menerima notifikasi pembayaran dari bank",[226,467,468],{},"Payment Provider memverifikasi dan memproses transaksi",[226,470,471],{},"Dana ditransfer ke rekening bank yang dituju",[208,473,474],{},[229,475,476],{},"5. Notifikasi Pembayaran (Bank → Payment Provider → Tripay)",[223,478,479,482,498,509,512],{},[226,480,481],{},"Bank mengirim konfirmasi pembayaran ke Payment Provider",[226,483,484,485],{},"Payment Provider mengirim webhook/callback ke Tripay:\n",[252,486,487,489,492,495],{},[226,488,399],{},[226,490,491],{},"Status pembayaran (success/failed)",[226,493,494],{},"Jumlah pembayaran",[226,496,497],{},"Timestamp pembayaran",[226,499,500,501],{},"Tripay menerima dan memvalidasi callback:\n",[252,502,503,506],{},[226,504,505],{},"Validasi sumber/signature callback",[226,507,508],{},"Cek referensi transaksi",[226,510,511],{},"Tripay update status transaksi di Database",[226,513,514],{},"Tripay mencatat detail pembayaran dan timestamp",[208,516,517],{},[229,518,519],{},"6. Notifikasi Merchant (Tripay → Merchant)",[223,521,522,538,541,544,547,550],{},[226,523,524,525],{},"Tripay Webhook Service mengirim callback ke callback URL merchant:\n",[252,526,527,529,532,535],{},[226,528,399],{},[226,530,531],{},"Order ID",[226,533,534],{},"Status pembayaran",[226,536,537],{},"Detail pembayaran",[226,539,540],{},"Server merchant menerima notifikasi callback",[226,542,543],{},"Merchant memvalidasi signature callback",[226,545,546],{},"Merchant update status pesanan di sistem mereka",[226,548,549],{},"Merchant mengirim konfirmasi pesanan ke customer (email/SMS/WhatsApp)",[226,551,552,553],{},"Merchant memproses pemenuhan pesanan:\n",[252,554,555,558,561],{},[226,556,557],{},"Generate invoice",[226,559,560],{},"Persiapan pengiriman",[226,562,563],{},"Aktivasi produk/layanan digital",[208,565,566],{},[229,567,568],{},"7. Konfirmasi Customer (Merchant → Customer)",[223,570,571,574,577,580],{},[226,572,573],{},"Customer menerima notifikasi pembayaran sukses",[226,575,576],{},"Customer menerima konfirmasi pesanan",[226,578,579],{},"Customer dapat melacak status pesanan",[226,581,582],{},"Transaksi selesai",[319,584,586],{"id":585},"proses-tambahan","Proses Tambahan",[208,588,589,250],{},[229,590,591],{},"Pelaporan & Analitik",[252,593,594,597,600,603],{},[226,595,596],{},"Semua aktivitas transaksi dicatat ke Database",[226,598,599],{},"Log aktivitas dikirim ke tools Analytics (Google Analytics, Clarity, PostHog)",[226,601,602],{},"Data transaksi tersedia di Metabase untuk reporting",[226,604,605],{},"Merchant dapat melihat laporan transaksi di dashboard Tripay",[208,607,608,250],{},[229,609,610],{},"Penanganan Transaksi Gagal",[252,612,613,616,619,622],{},[226,614,615],{},"Jika pembayaran gagal atau kadaluarsa, status diupdate sesuai",[226,617,618],{},"Notifikasi webhook dikirim ke merchant dengan status gagal",[226,620,621],{},"Customer diberitahu tentang kegagalan pembayaran",[226,623,624],{},"Customer dapat mencoba ulang pembayaran atau membatalkan pesanan",{"title":626,"searchDepth":627,"depth":627,"links":628},"",2,[629,630],{"id":220,"depth":627,"text":221},{"id":316,"depth":627,"text":317,"children":631},[632,634,635],{"id":321,"depth":633,"text":322},3,{"id":330,"depth":633,"text":331},{"id":585,"depth":633,"text":586},null,"md",{},{"icon":17},{"title":162,"description":636},"W1vu19NX-kJ5qxHaKEra_cMJnFv9AkTt1HnJ3HksgsU",[643,645],{"title":158,"path":159,"stem":160,"description":644,"children":-1},"This section explains the development workflow and processes.",{"title":166,"path":167,"stem":168,"description":646,"icon":17,"children":-1},"Arsitektur Laravel MVC dengan integrasi frontend Vue.js",1766367451788]