mer->>Customer: Terima konfirmasi\n",[336,679,681],{"class":338,"line":680},59,[336,682,683],{},"    Customer->>Merchant: Lacak status pesanan\n",[336,685,687],{"class":338,"line":686},60,[336,688,379],{"emptyLinePlaceholder":378},[336,690,692],{"class":338,"line":691},61,[336,693,694],{},"    Note over Customer,Bank: Transaksi Selesai ✓\n",[321,696,698],{"id":697},"alur-transaksi-lengkap","Alur Transaksi Lengkap",[210,700,701],{},[231,702,703],{},"1. Customer Memulai Pembelian (Customer → Merchant)",[225,705,706,709,712,715,718],{},[228,707,708],{},"Customer menjelajahi produk/layanan di website merchant",[228,710,711],{},"Customer menambahkan item ke keranjang dan melanjutkan ke checkout",[228,713,714],{},"Customer mengisi detail pesanan (info pengiriman, kontak, dll.)",[228,716,717],{},"Customer memilih metode pembayaran dan mengkonfirmasi pesanan",[228,719,720],{},"Server merchant menerima data pesanan dan mempersiapkan transaksi",[210,722,723],{},[231,724,725],{},"2. Inisiasi Transaksi (Merchant → Tripay)",[225,727,728,736,739,753,756,759],{},[228,729,730,731],{},"Server merchant mengirim request API ke Tripay dengan detail transaksi:\n",[254,732,733],{},[228,734,735],{},"Order ID, jumlah, info customer, metode pembayaran yang dipilih",[228,737,738],{},"Request melewati layer Cloudflare",[228,740,741,742],{},"Tripay Web App menerima dan memvalidasi request:\n",[254,743,744,747,750],{},[228,745,746],{},"Validasi kredensial API (Merchant Code, API Key, Signature)",[228,748,749],{},"Validasi parameter request",[228,751,752],{},"Cek status merchant dan saldo",[228,754,755],{},"Tripay membuat record transaksi di Database",[228,757,758],{},"Tripay generate instruksi pembayaran/nomor referensi",[228,760,761,762],{},"Tripay mengembalikan response API ke merchant dengan:\n",[254,763,764,767,770,773,776],{},[228,765,766],{},"Referensi transaksi",[228,768,769],{},"Instruksi pembayaran",[228,771,772],{},"QR code (untuk QRIS)",[228,774,775],{},"Nomor virtual account (untuk 