hatsApp","/id/introduction/notification/whatsapp-notification","id/1.introduction/6.notification/1.whatsapp-notification",{"title":114,"icon":16,"path":115,"stem":116,"children":117,"page":16},"Integrasi","/id/introduction/integrations","id/1.introduction/7.integrations",[118,122,126,130],{"title":119,"path":120,"stem":121,"icon":16},"Callback tester","/id/introduction/integrations/callback-tester","id/1.introduction/7.integrations/1.callback-tester",{"title":123,"path":124,"stem":125,"icon":16},"Sandbox","/id/introduction/integrations/sandbox","id/1.introduction/7.integrations/2.sandbox",{"title":127,"path":128,"stem":129,"icon":16},"Production","/id/introduction/integrations/production","id/1.introduction/7.integrations/3.production",{"title":131,"path":132,"stem":133,"icon":16},"Plugin","/id/introduction/integrations/plugin","id/1.introduction/7.integrations/4.plugin",{"title":135,"icon":16,"path":136,"stem":137,"children":138,"page":16},"Referral","/id/introduction/referral","id/1.introduction/8.referral",[139],{"title":135,"path":140,"stem":141,"icon":16},"/id/introduction/referral/referral","id/1.introduction/8.referral/1.referral",{"title":143,"icon":16,"path":144,"stem":145,"children":146,"page":16},"FAQs","/id/introduction/faqs","id/1.introduction/9.faqs",[147],{"title":143,"path":148,"stem":149,"icon":16},"/id/introduction/faqs/faqs","id/1.introduction/9.faqs/1.faqs",{"title":151,"path":152,"stem":153,"children":154,"page":16},"Developer Guide","/id/developer-guide","id/2.developer-guide",[155,159,163,167,171,175,179,183,187],{"title":156,"path":157,"stem":158},"Installation and Requirements","/id/developer-guide/installation-and-requirements","id/2.developer-guide/1.installation-and-requirements",{"title":160,"path":161,"stem":162},"Development Workflow","/id/developer-guide/development-workflow","id/2.developer-guide/2.development-workflow",{"title":164,"path":165,"stem":166,"icon":16},"Arsitektur Sistem","/id/developer-guide/system-architecture","id/2.developer-guide/3.system-architecture",{"title":168,"path":169,"stem":170,"icon":16},"Arsitektur Backend","/id/developer-guide/backend-architecture","id/2.developer-guide/4.backend-architecture",{"title":172,"path":173,"stem":174},"Frontend Architecture","/id/developer-guide/frontend-architecture","id/2.developer-guide/5.frontend-architecture",{"title":176,"path":177,"stem":178},"Database","/id/developer-guide/database","id/2.developer-guide/6.database",{"title":180,"path":181,"stem":182},"Coding Standard","/id/developer-guide/coding-standard","id/2.developer-guide/7.coding-standard",{"title":184,"path":185,"stem":186},"Best Practices","/id/developer-guide/best-practices","id/2.developer-guide/8.best-practices",{"title":188,"path":189,"stem":190},"Testing","/id/developer-guide/testing","id/2.developer-guide/9.testing",{"title":192,"path":193,"stem":194,"children":195,"page":16},"Api References","/id/api-references","id/3.api-references",[196,200],{"title":197,"path":198,"stem":199},"API Endpoints","/id/api-references/api-endpoints","id/3.api-references/1.api-endpoints",{"title":201,"path":202,"stem":203},"Usage Guide","/id/api-references/usage-guide","id/3.api-references/2.usage-guide",{"id":205,"title":164,"body":206,"description":1004,"extension":1005,"links":1004,"meta":1006,"navigation":1007,"path":165,"seo":1008,"stem":166,"__hash__":1009},"docs_id/id/2.developer-guide/3.system-architecture.md",{"type":207,"value":208,"toc":996},"minimark",[209,213,219,224,316,320,325,695,699,704,721,726,779,784,806,811,839,844,882,887,931,936,950,954,959,973,978,992],[210,211,212],"p",{},"Sistem TriPay didesain untuk memproses transaksi pembayaran dengan aman dan stabil bagi end-users melalui API dan berinteraksi dengan web app Laravel + Vue melalui setup server yang terpisah, sesuai dengan penggunaannya.",[210,214,215],{},[216,217],"img",{"alt":164,"src":218},"/images/system-architecture.png",[220,221,223],"h2",{"id":222},"rincian-komponen","Rincian Komponen",[225,226,227,235,241,247,273,279,285],"ol",{},[228,229,230,234],"li",{},[231,232,233],"strong",{},"End-User",": Pengguna akhir berinteraksi dengan website Tripay untuk melakukan pendaftaran, konfigurasi merchant, dan melihat detail transaksi.",[228,236,237,240],{},[231,238,239],{},"Merchant Server",": Server merchant yang melakukan integrasi API Tripay untuk memproses transaksi.",[228,242,243,246],{},[231,244,245],{},"Lapisan Cloudflare",": Semua traffic masuk dan keluar dialihkan melalui Cloudflare untuk menyediakan perlindungan DDoS, aturan pemfilteran IP, dan caching resource.",[228,248,249,252,253],{},[231,250,251],{},"Server Kolokasi Maxcloud",":",[254,255,256,262,268],"ul",{},[228,257,258,261],{},[231,259,260],{},"Webhook Service",": Mengirim notifikasi asinkron (callback) dari Tripay ke server merchant terkait pembaruan status transaksi.",[228,263,264,267],{},[231,265,266],{},"Web App",": Aplikasi monolith Laravel yang menangani layanan frontend (Vue.js) dan backend, termasuk user interface, pemrosesan logika bisnis, dan API endpoint untuk integrasi merchant.",[228,269,270,272],{},[231,271,176],{},": Sistem database relasional untuk menyimpan data pengguna, catatan transaksi, pengaturan, dan log.",[228,274,275,278],{},[231,276,277],{},"Penyedia Layanan Pembayaran",": Sistem terhubung ke beberapa penyedia layanan pembayaran dan agregator (misalnya, Bank BCA, BNI, Neo, NOBU, Prismalink, DurianPay, LinkQu, Esmartlink, PakaiLink) untuk memproses berbagai macam pembayaran bank/QRIS.",[228,280,281,284],{},[231,282,283],{},"Bank",": Tujuan akhir dari dana settlement; perpindahan uang yang sebenarnya terjadi di sini melalui integrasi penyedia layanan pembayaran.",[228,286,287,252,290],{},[231,288,289],{},"Integrasi & Tools Pihak Ketiga",[254,291,292,298,304,310],{},[228,293,294,297],{},[231,295,296],{},"Email dan Storage",": Amazon SES untuk pengiriman email transaksional dan S3 untuk menyimpan file dan data pengguna.",[228,299,300,303],{},[231,301,302],{},"Analytics",": Google Analytics, Microsoft Clarity, dan PostHog untuk pelacakan aktivitas pengguna, analitik produk, dan heatmap.",[228,305,306,309],{},[231,307,308],{},"Layanan Pihak Ketiga",": Verihubs dan Gemini untuk verifikasi identitas/KYC, WhatsApp API untuk notifikasi pelanggan.",[228,311,312,315],{},[231,313,314],{},"Tools Lainnya",": n8n untuk otomatisasi workflow, Metabase untuk analitik data/dashboard, OpnForm untuk manajemen form dan use case internal.",[220,317,319],{"id":318},"alur-data-dan-proses","Alur Data dan Proses",[321,322,324],"h3",{"id":323},"diagram-aktivitas-transaksi","Diagram Aktivitas Transaksi",[326,327,332],"pre",{"className":328,"code":329,"language":330,"meta":331,"style":331},"language-mermaid shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","sequenceDiagram\n    participant Customer\n    participant Merchant\n    participant Tripay\n    participant Provider as Payment Provider\n    participant Bank\n\n    Note over Customer,Bank: Alur Transaksi dengan 5 Aktor\n\n    %% Fase 1: Customer Memulai Pembelian\n    Customer->>Merchant: Browse produk & tambah ke keranjang\n    Customer->>Merchant: Lanjut ke checkout\n    Customer->>Merchant: Isi detail pesanan & pilih metode pembayaran\n    Customer->>Merchant: Konfirmasi pesanan\n\n    %% Fase 2: Inisiasi Transaksi\n    Merchant->>Merchant: Persiapkan data transaksi\n    Merchant->>Tripay: POST /transaction/create\u003Cbr/>(Order ID, Jumlah, Metode Pembayaran)\n\n    Tripay->>Tripay: Validasi kredensial API\n    Tripay->>Tripay: Validasi parameter request\n    Tripay->>Tripay: Cek status merchant\n    Tripay->>Tripay: Buat record transaksi di DB\n    Tripay->>Provider: Request payment channel\u003Cbr/>(Nomor VA/QR Code)\n    Provider->>Tripay: Return detail pembayaran\n    Tripay->>Tripay: Generate referensi pembayaran\n    Tripay->>Merchant: Return API response\u003Cbr/>(Referensi, VA/QR, Instruksi)\n\n    %% Fase 3: Tampilkan Pembayaran\n    Merchant->>Merchant: Proses response Tripay\n    Merchant->>Customer: Tampilkan instruksi pembayaran\u003Cbr/>(QR Code/Nomor VA, Jumlah, Expiry)\n\n    %% Fase 4: Proses Pembayaran\n    Customer->>Bank: Scan QR Code / Transfer ke VA\n    Bank->>Bank: Proses transaksi\n    Bank->>Bank: Kurangi saldo customer\n    Bank->>Provider: Kirim notifikasi pembayaran\n    Provider->>Provider: Verifikasi transaksi\n    Provider->>Bank: Request settlement dana\n    Bank->>Provider: Transfer dana\n\n    %% Fase 5: Konfirmasi Pembayaran ke Tripay\n    Provider->>Tripay: Kirim webhook/callback\u003Cbr/>(Referensi, Status, Jumlah, Timestamp)\n    Tripay->>Tripay: Validasi signature callback\n    Tripay->>Tripay: Verifikasi referensi transaksi\n    Tripay->>Tripay: Update status transaksi ke PAID\n    Tripay->>Tripay: Catat detail pembayaran\n\n    %% Fase 6: Notifikasi Merchant\n    Tripay->>Merchant: Kirim webhook callback\u003Cbr/>(Order ID, Status, Detail Pembayaran)\n    Merchant->>Merchant: Validasi signature callback\n    Merchant->>Merchant: Update status pesanan\n    Merchant->>Merchant: Proses pemenuhan pesanan\n\n    %% Fase 7: Konfirmasi Customer\n    Merchant->>Customer: Kirim notifikasi pembayaran sukses\u003Cbr/>(Email/SMS/WhatsApp)\n    Merchant->>Customer: Kirim konfirmasi pesanan & invoice\n    Customer->>Customer: Terima konfirmasi\n    Customer->>Merchant: Lacak status pesanan\n\n    Note over Customer,Bank: Transaksi Selesai ✓\n","mermaid","",[333,334,335,343,349,355,361,367,373,380,386,391,397,403,409,415,421,426,432,438,444,449,455,461,467,473,479,485,491,497,502,508,514,520,525,531,537,543,549,555,561,567,573,578,584,590,596,602,608,614,619,625,631,637,643,649,654,660,666,672,678,684,689],"code",{"__ignoreMap":331},[336,337,340],"span",{"class":338,"line":339},"line",1,[336,341,342],{},"sequenceDiagram\n",[336,344,346],{"class":338,"line":345},2,[336,347,348],{},"    participant Customer\n",[336,350,352],{"class":338,"line":351},3,[336,353,354],{},"    participant Merchant\n",[336,356,358],{"class":338,"line":357},4,[336,359,360],{},"    participant Tripay\n",[336,362,364],{"class":338,"line":363},5,[336,365,366],{},"    participant Provider as Payment Provider\n",[336,368,370],{"class":338,"line":369},6,[336,371,372],{},"    participant Bank\n",[336,374,376],{"class":338,"line":375},7,[336,377,379],{"emptyLinePlaceholder":378},true,"\n",[336,381,383],{"class":338,"line":382},8,[336,384,385],{},"    Note over Customer,Bank: Alur Transaksi dengan 5 Aktor\n",[336,387,389],{"class":338,"line":388},9,[336,390,379],{"emptyLinePlaceholder":378},[336,392,394],{"class":338,"line":393},10,[336,395,396],{},"    %% Fase 1: Customer Memulai Pembelian\n",[336,398,400],{"class":338,"line":399},11,[336,401,402],{},"    Customer->>Merchant: Browse produk & tambah ke keranjang\n",[336,404,406],{"class":338,"line":405},12,[336,407,408],{},"    Customer->>Merchant: Lanjut ke checkout\n",[336,410,412],{"class":338,"line":411},13,[336,413,414],{},"    Customer->>Merchant: Isi detail pesanan & pilih metode pembayaran\n",[336,416,418],{"class":338,"line":417},14,[336,419,420],{},"    Customer->>Merchant: Konfirmasi pesanan\n",[336,422,424],{"class":338,"line":423},15,[336,425,379],{"emptyLinePlaceholder":378},[336,427,429],{"class":338,"line":428},16,[336,430,431],{},"    %% Fase 2: Inisiasi Transaksi\n",[336,433,435],{"class":338,"line":434},17,[336,436,437],{},"    Merchant->>Merchant: Persiapkan data transaksi\n",[336,439,441],{"class":338,"line":440},18,[336,442,443],{},"    Merchant->>Tripay: POST /transaction/create\u003Cbr/>(Order ID, Jumlah, Metode Pembayaran)\n",[336,445,447],{"class":338,"line":446},19,[336,448,379],{"emptyLinePlaceholder":378},[336,450,452],{"class":338,"line":451},20,[336,453,454],{},"    Tripay->>Tripay: Validasi kredensial API\n",[336,456,458],{"class":338,"line":457},21,[336,459,460],{},"    Tripay->>Tripay: Validasi parameter request\n",[336,462,464],{"class":338,"line":463},22,[336,465,466],{},"    Tripay->>Tripay: Cek status merchant\n",[336,468,